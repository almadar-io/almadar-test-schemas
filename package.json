{
  "name": "@almadar/test-schemas",
  "version": "2.1.4",
  "private": true,
  "exports": {
    "./schemas/*": "./schemas/*.orb",
    "./training-data/*": "./training-data/*"
  },
  "scripts": {
    "validate": "for f in ./schemas/*.orb; do echo \"Validating $f\"; orbital validate \"$f\"; done",
    "prepare": "git config core.hooksPath .githooks"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-test-schemas.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "turbo": "^2.8.17"
  }
}
