{
  "name": "Product Management",
  "entity": {
    "name": "Product",
    "collection": "products",
    "fields": [
      {
        "name": "name",
        "type": "string",
        "required": true
      },
      {
        "name": "price",
        "type": "number",
        "required": true,
        "default": 0
      },
      {
        "name": "quantity",
        "type": "number",
        "required": true,
        "default": 0
      },
      {
        "name": "status",
        "type": "enum",
        "values": [
          "active",
          "inactive",
          "discontinued"
        ],
        "required": true,
        "default": "active"
      },
      {
        "name": "description",
        "type": "string"
      },
      {
        "name": "sku",
        "type": "string"
      },
      {
        "name": "category",
        "type": "string"
      },
      {
        "name": "createdAt",
        "type": "date"
      },
      {
        "name": "updatedAt",
        "type": "date"
      }
    ]
  },
  "traits": [
    {
      "name": "ProductStatus",
      "category": "state",
      "linkedEntity": "Product",
      "stateMachine": {
        "states": [
          {
            "name": "Active",
            "isInitial": true
          },
          {
            "name": "Inactive"
          },
          {
            "name": "Discontinued"
          }
        ],
        "events": [
          {
            "key": "ACTIVATE",
            "name": "Activate"
          },
          {
            "key": "DEACTIVATE",
            "name": "Deactivate"
          },
          {
            "key": "DISCONTINUE",
            "name": "Discontinue"
          },
          {
            "key": "REACTIVATE",
            "name": "Reactivate"
          }
        ],
        "transitions": [
          {
            "from": "Active",
            "to": "Inactive",
            "event": "DEACTIVATE"
          },
          {
            "from": "Active",
            "to": "Discontinued",
            "event": "DISCONTINUE"
          },
          {
            "from": "Inactive",
            "to": "Active",
            "event": "ACTIVATE"
          },
          {
            "from": "Inactive",
            "to": "Discontinued",
            "event": "DISCONTINUE"
          },
          {
            "from": "Discontinued",
            "to": "Active",
            "event": "REACTIVATE"
          }
        ]
      }
    },
    {
      "name": "EntityManagement",
      "category": "interaction",
      "linkedEntity": "Product",
      "stateMachine": {
        "states": [
          {
            "name": "browsing",
            "isInitial": true
          },
          {
            "name": "creating"
          },
          {
            "name": "viewing"
          },
          {
            "name": "editing"
          },
          {
            "name": "deleting"
          }
        ],
        "events": [
          {
            "key": "INIT",
            "name": "Initialize"
          },
          {
            "key": "CREATE",
            "name": "Create"
          },
          {
            "key": "VIEW",
            "name": "View"
          },
          {
            "key": "EDIT",
            "name": "Edit"
          },
          {
            "key": "DELETE",
            "name": "Delete"
          },
          {
            "key": "SAVE",
            "name": "Save"
          },
          {
            "key": "CANCEL",
            "name": "Cancel"
          },
          {
            "key": "CONFIRM_DELETE",
            "name": "Confirm Delete"
          }
        ],
        "transitions": [
          {
            "from": "browsing",
            "to": "browsing",
            "event": "INIT",
            "effects": [
              [
                "render-ui",
                "main",
                {
                  "type": "page-header",
                  "title": "Products",
                  "actions": [
                    {
                      "label": "New Product",
                      "event": "CREATE",
                      "variant": "primary"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "search-bar",
                  "placeholder": "Search products...",
                  "entity": "Product"
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "filter-group",
                  "filters": [
                    {
                      "field": "status",
                      "filterType": "select",
                      "label": "Status",
                      "options": [
                        "active",
                        "inactive",
                        "discontinued"
                      ]
                    },
                    {
                      "field": "category",
                      "filterType": "select",
                      "label": "Category",
                      "options": []
                    },
                    {
                      "field": "price",
                      "filterType": "number-range",
                      "label": "Price Range"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "entity-table",
                  "entity": "Product",
                  "columns": [
                    "name",
                    "sku",
                    "price",
                    "quantity",
                    "status",
                    "category"
                  ],
                  "itemActions": [
                    {
                      "label": "View",
                      "event": "VIEW",
                      "placement": "row"
                    },
                    {
                      "label": "Edit",
                      "event": "EDIT",
                      "placement": "menu"
                    },
                    {
                      "label": "Delete",
                      "event": "DELETE",
                      "placement": "menu",
                      "isDestructive": true
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "creating",
            "event": "CREATE",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "entity": "Product",
                  "title": "Create Product",
                  "fields": [
                    {
                      "field": "name",
                      "label": "Product Name",
                      "inputType": "text"
                    },
                    {
                      "field": "description",
                      "label": "Description",
                      "inputType": "textarea"
                    },
                    {
                      "field": "sku",
                      "label": "SKU",
                      "inputType": "text"
                    },
                    {
                      "field": "price",
                      "label": "Price",
                      "inputType": "number"
                    },
                    {
                      "field": "quantity",
                      "label": "Quantity",
                      "inputType": "number"
                    },
                    {
                      "field": "category",
                      "label": "Category",
                      "inputType": "text"
                    },
                    {
                      "field": "status",
                      "label": "Status",
                      "inputType": "select",
                      "values": [
                        "active",
                        "inactive",
                        "discontinued"
                      ]
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "form-actions",
                  "primary": {
                    "label": "Create Product",
                    "event": "SAVE",
                    "actionType": "submit"
                  },
                  "secondary": [
                    {
                      "label": "Cancel",
                      "event": "CANCEL",
                      "actionType": "cancel"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "viewing",
            "event": "VIEW",
            "effects": [
              [
                "render-ui",
                "drawer",
                {
                  "type": "entity-detail",
                  "entity": "Product",
                  "fieldNames": [
                    "name",
                    "description",
                    "sku",
                    "price",
                    "quantity",
                    "category",
                    "status",
                    "createdAt",
                    "updatedAt"
                  ],
                  "actions": [
                    {
                      "label": "Edit",
                      "event": "EDIT",
                      "variant": "primary"
                    },
                    {
                      "label": "Delete",
                      "event": "DELETE",
                      "variant": "danger"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "editing",
            "event": "EDIT",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "entity": "Product",
                  "title": "Edit Product",
                  "fields": [
                    {
                      "field": "name",
                      "label": "Product Name",
                      "inputType": "text"
                    },
                    {
                      "field": "description",
                      "label": "Description",
                      "inputType": "textarea"
                    },
                    {
                      "field": "sku",
                      "label": "SKU",
                      "inputType": "text"
                    },
                    {
                      "field": "price",
                      "label": "Price",
                      "inputType": "number"
                    },
                    {
                      "field": "quantity",
                      "label": "Quantity",
                      "inputType": "number"
                    },
                    {
                      "field": "category",
                      "label": "Category",
                      "inputType": "text"
                    },
                    {
                      "field": "status",
                      "label": "Status",
                      "inputType": "select",
                      "values": [
                        "active",
                        "inactive",
                        "discontinued"
                      ]
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "form-actions",
                  "primary": {
                    "label": "Save Changes",
                    "event": "SAVE",
                    "actionType": "submit"
                  },
                  "secondary": [
                    {
                      "label": "Cancel",
                      "event": "CANCEL",
                      "actionType": "cancel"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "editing",
            "event": "EDIT",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "entity": "Product",
                  "title": "Edit Product",
                  "fields": [
                    {
                      "field": "name",
                      "label": "Product Name",
                      "inputType": "text"
                    },
                    {
                      "field": "description",
                      "label": "Description",
                      "inputType": "textarea"
                    },
                    {
                      "field": "sku",
                      "label": "SKU",
                      "inputType": "text"
                    },
                    {
                      "field": "price",
                      "label": "Price",
                      "inputType": "number"
                    },
                    {
                      "field": "quantity",
                      "label": "Quantity",
                      "inputType": "number"
                    },
                    {
                      "field": "category",
                      "label": "Category",
                      "inputType": "text"
                    },
                    {
                      "field": "status",
                      "label": "Status",
                      "inputType": "select",
                      "values": [
                        "active",
                        "inactive",
                        "discontinued"
                      ]
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "form-actions",
                  "primary": {
                    "label": "Save Changes",
                    "event": "SAVE",
                    "actionType": "submit"
                  },
                  "secondary": [
                    {
                      "label": "Cancel",
                      "event": "CANCEL",
                      "actionType": "cancel"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "deleting",
            "event": "DELETE",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "confirmation-dialog",
                  "title": "Delete Product",
                  "message": "Are you sure you want to delete this product? This action cannot be undone.",
                  "confirmLabel": "Delete",
                  "cancelLabel": "Cancel",
                  "confirmEvent": "CONFIRM_DELETE",
                  "cancelEvent": "CANCEL",
                  "variant": "danger"
                }
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "deleting",
            "event": "DELETE",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "confirmation-dialog",
                  "title": "Delete Product",
                  "message": "Are you sure you want to delete this product? This action cannot be undone.",
                  "confirmLabel": "Delete",
                  "cancelLabel": "Cancel",
                  "confirmEvent": "CONFIRM_DELETE",
                  "cancelEvent": "CANCEL",
                  "variant": "danger"
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "persist",
                "create",
                "Product",
                "@form"
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "success",
                  "message": "Product created successfully"
                }
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "persist",
                "update",
                "Product",
                "@form"
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "success",
                  "message": "Product updated successfully"
                }
              ]
            ]
          },
          {
            "from": "deleting",
            "to": "browsing",
            "event": "CONFIRM_DELETE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "persist",
                "delete",
                "Product",
                "@entity"
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "success",
                  "message": "Product deleted successfully"
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ]
            ]
          },
          {
            "from": "deleting",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          }
        ]
      }
    }
  ],
  "pages": [
    {
      "name": "ProductsPage",
      "path": "/products",
      "viewType": "list",
      "primaryEntity": "Product",
      "isInitial": true,
      "traits": [
        {
          "ref": "EntityManagement"
        }
      ]
    }
  ],
  "emits": [
    "PRODUCT_CREATED",
    "PRODUCT_UPDATED",
    "PRODUCT_DELETED",
    "PRODUCT_STATUS_CHANGED"
  ],
  "listens": [
    "INVENTORY_UPDATED",
    "ORDER_PLACED"
  ]
}