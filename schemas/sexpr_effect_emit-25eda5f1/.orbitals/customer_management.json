                      "inputType": "email",
                      "required": true
                    },
                    {
                      "field": "firstName",
                      "label": "First Name",
                      "inputType": "text",
                      "required": true
                    },
                    {
                      "field": "lastName",
                      "label": "Last Name",
                      "inputType": "text",
                      "required": true
                    },
                    {
                      "field": "phone",
                      "label": "Phone",
                      "inputType": "text"
                    },
                    {
                      "field": "status",
                      "label": "Status",
                      "inputType": "select",
                      "values": [
                        "active",
                        "inactive",
                        "suspended"
                      ]
                    },
                    {
                      "field": "totalOrders",
                      "label": "Total Orders",
                      "inputType": "number"
                    },
                    {
                      "field": "totalSpent",
                      "label": "Total Spent",
                      "inputType": "number"
                    },
                    {
                      "field": "lastOrderDate",
                      "label": "Last Order Date",
                      "inputType": "date"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "form-actions",
                  "primary": {
                    "label": "Save Changes",
                    "event": "SAVE",
                    "actionType": "submit",
                    "variant": "primary"
                  },
                  "secondary": [
                    {
                      "label": "Cancel",
                      "event": "CLOSE",
                      "actionType": "cancel",
                      "variant": "secondary"
                    }
                  ]
                }
              ]
            ]
          },
