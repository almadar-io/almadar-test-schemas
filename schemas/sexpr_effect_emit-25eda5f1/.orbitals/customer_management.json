  "pages": [
    {
      "name": "CustomersPage",
      "path": "/customers",
      "viewType": "list",
      "primaryEntity": "Customer",
      "isInitial": true,
      "traits": [
        {
          "ref": "CustomerManagement"
        }
      ]
    }
  ],
  "emits": [
    "CUSTOMER_CREATED",
    "CUSTOMER_UPDATED",
    "CUSTOMER_DELETED"
  ],
  "listens": [
