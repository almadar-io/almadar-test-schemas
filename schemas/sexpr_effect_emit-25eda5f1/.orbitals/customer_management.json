                      "inputType": "text",
                      "required": true
                    },
                    {
                      "field": "phone",
                      "label": "Phone",
                      "inputType": "text"
                    },
                    {
                      "field": "status",
                      "label": "Status",
                      "inputType": "select",
                      "values": [
                        "active",
                        "inactive",
                        "suspended"
                      ]
                    },
                    {
                      "field": "totalOrders",
                      "label": "Total Orders",
                      "inputType": "number"
                    },
                    {
                      "field": "totalSpent",
                      "label": "Total Spent",
                      "inputType": "number"
                    },
                    {
                      "field": "lastOrderDate",
                      "label": "Last Order Date",
                      "inputType": "date"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "form-actions",
                  "primary": {
                    "label": "Save Changes",
                    "event": "SAVE",
                    "actionType": "submit",
                    "variant": "primary"
                  },
                  "secondary": [
                    {
                      "label": "Cancel",
                      "event": "CLOSE",
                      "actionType": "cancel",
                      "variant": "secondary"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "persist",
                "create",
                "Customer",
                "@form"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "success",
                  "message": "Customer created successfully"
                }
              ]
            ]
          },
          {
