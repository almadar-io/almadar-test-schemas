    {
      "name": "Order Management",
      "entity": {
        "name": "Order",
        "collection": "orders",
        "fields": [
          {
            "name": "id",
            "type": "string",
            "required": true
          },
          {
            "name": "customerEmail",
            "type": "string",
            "required": true
          },
          {
            "name": "amount",
            "type": "number",
            "required": true
          },
          {
            "name": "status",
            "type": "enum",
            "values": [
              "pending",
              "processing",
              "shipped",
              "delivered",
              "cancelled"
            ],
            "required": true
          },
          {
            "name": "orderDate",
            "type": "date",
            "required": true
          },
          {
            "name": "items",
            "type": "array"
          },
          {
            "name": "shippingAddress",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "FormSubmission",
          "category": "interaction",
          "linkedEntity": "Order",
          "stateMachine": {
            "states": [
              {
                "name": "Idle",
                "isInitial": true
              },
              {
                "name": "Submitting"
              },
              {
                "name": "Success"
              },
              {
                "name": "Error"
              }
            ],
            "events": [
              {
                "key": "SUBMIT",
                "name": "Submit"
              },
              {
                "key": "SUCCESS",
                "name": "Success"
              },
              {
                "key": "ERROR",
                "name": "Error"
              },
              {
                "key": "RESET",
                "name": "Reset"
              }
            ],
            "transitions": [
              {
                "from": "Idle",
                "to": "Submitting",
                "event": "SUBMIT",
                "effects": [
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Submitting order...",
                      "variant": "info"
                    }
                  ],
                  [
                    "persist",
                    "create",
                    "Order",
                    "@form"
                  ]
                ]
              },
              {
                "from": "Submitting",
                "to": "Success",
                "event": "SUCCESS",
                "effects": [
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Order created successfully!",
                      "variant": "success"
                    }
                  ],
                  [
                    "navigate",
                    "/orders"
                  ]
                ]
              },
              {
                "from": "Submitting",
                "to": "Error",
                "event": "ERROR",
                "effects": [
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Failed to create order. Please try again.",
                      "variant": "error"
                    }
                  ]
                ]
              },
              {
                "from": "Success",
                "to": "Idle",
                "event": "RESET",
                "effects": []
              },
              {
                "from": "Error",
                "to": "Idle",
                "event": "RESET",
                "effects": []
              }
            ]
          }
        },
        {
          "name": "OrderLifecycle",
          "category": "business",
          "linkedEntity": "Order",
          "stateMachine": {
            "states": [
              {
                "name": "pending",
                "isInitial": true
              },
              {
                "name": "processing"
              },
              {
                "name": "shipped"
              },
              {
                "name": "delivered"
              },
              {
                "name": "cancelled"
              }
            ],
            "events": [
              {
                "key": "PROCESS",
                "name": "Process Order"
              },
              {
                "key": "SHIP",
                "name": "Ship Order"
              },
              {
                "key": "DELIVER",
                "name": "Mark Delivered"
              },
              {
                "key": "CANCEL",
                "name": "Cancel Order"
              }
            ],
            "transitions": [
              {
                "from": "pending",
                "to": "processing",
                "event": "PROCESS",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Order",
                    {
                      "status": "processing"
                    }
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Order is now being processed",
                      "variant": "info"
                    }
                  ]
                ]
              },
              {
                "from": "processing",
                "to": "shipped",
                "event": "SHIP",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Order",
                    {
                      "status": "shipped"
                    }
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Order has been shipped",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "shipped",
                "to": "delivered",
                "event": "DELIVER",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Order",
                    {
                      "status": "delivered"
                    }
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Order delivered successfully",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "pending",
                "to": "cancelled",
                "event": "CANCEL",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Order",
                    {
                      "status": "cancelled"
                    }
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Order has been cancelled",
                      "variant": "warning"
                    }
                  ]
                ]
              },
              {
                "from": "processing",
                "to": "cancelled",
                "event": "CANCEL",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Order",
                    {
                      "status": "cancelled"
                    }
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Order has been cancelled",
                      "variant": "warning"
                    }
                  ]
                ]
              }
            ]
          }
        },
