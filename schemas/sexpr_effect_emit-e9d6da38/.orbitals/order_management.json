              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Order has been shipped",
                  "variant": "success"
                }
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "processing",
            "event": "DELIVER",
            "effects": [
              [
                "persist",
                "update",
                "Order",
                {
                  "status": "delivered"
                }
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Order marked as delivered",
                  "variant": "success"
                }
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "processing",
            "event": "CANCEL",
            "effects": [
              [
                "persist",
                "update",
                "Order",
                {
                  "status": "cancelled"
                }
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Order has been cancelled",
                  "variant": "success"
                }
              ]
            ]
          },
          {
            "from": "processing",
            "to": "browsing",
            "event": "INIT",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "page-header",
                  "title": "Orders",
                  "actions": [
                    {
                      "label": "New Order",
                      "event": "CREATE",
                      "variant": "primary"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "filter-group",
                  "filters": [
                    {
                      "field": "status",
                      "filterType": "select",
                      "label": "Status",
                      "options": [
                        "pending",
                        "confirmed",
                        "processing",
                        "shipped",
                        "delivered",
                        "cancelled"
                      ]
                    },
                    {
                      "field": "orderDate",
                      "filterType": "date-range",
                      "label": "Order Date"
                    },
                    {
                      "field": "customerEmail",
                      "filterType": "search",
                      "label": "Customer Email"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "entity-table",
                  "entity": "Order",
                  "columns": [
                    "id",
                    "customerEmail",
                    "amount",
                    "status",
                    "orderDate"
                  ],
                  "itemActions": [
                    {
                      "label": "View",
                      "event": "VIEW",
                      "placement": "row"
                    },
                    {
                      "label": "Edit",
                      "event": "EDIT",
                      "placement": "menu"
                    },
                    {
                      "label": "Cancel",
                      "event": "CANCEL",
                      "placement": "menu",
                      "isDestructive": true
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "persist",
                "create",
                "Order",
                "@form"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Order created successfully",
                  "variant": "success"
                }
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "persist",
                "update",
                "Order",
                "@form"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Order updated successfully",
                  "variant": "success"
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "CLOSE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "CLOSE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "browsing",
            "event": "CLOSE",
            "effects": [
