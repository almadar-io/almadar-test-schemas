  ],
  "pages": [
    {
      "name": "OrdersPage",
      "path": "/orders",
      "viewType": "list",
      "primaryEntity": "Order",
      "isInitial": true,
      "traits": [
        {
          "ref": "OrderLifecycle"
        }
      ]
    },
    {
      "name": "OrderDashboard",
      "path": "/orders/dashboard",
      "viewType": "dashboard",
      "primaryEntity": "Order",
      "traits": [
        {
          "ref": "OrderDashboard"
        }
      ]
    }
  ],
  "emits": [
    "ORDER_CREATED",
    "ORDER_UPDATED",
    "ORDER_STATUS_CHANGED",
    "ORDER_CANCELLED"
  ],
  "listens": [
    "PAYMENT_PROCESSED",
    "INVENTORY_UPDATED"
  ]
}