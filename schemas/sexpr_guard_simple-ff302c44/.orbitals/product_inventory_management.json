  "pages": [
    {
      "name": "ProductInventoryPage",
      "path": "/products",
      "viewType": "list",
      "primaryEntity": "Product",
      "isInitial": true,
      "traits": [
        {
          "ref": "ProductInteraction"
        }
      ]
    },
    {
      "name": "ProductDetailPage",
      "path": "/products/:id",
      "viewType": "detail",
      "primaryEntity": "Product",
      "traits": [
        {
          "ref": "ProductInteraction"
        }
      ]
    }
