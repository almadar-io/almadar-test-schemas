{
  "name": "Product Inventory Management",
  "entity": {
    "name": "Product",
    "collection": "products",
    "fields": [
      {
        "name": "name",
        "type": "string",
        "required": true
      },
      {
        "name": "description",
        "type": "string"
      },
      {
        "name": "price",
        "type": "number",
        "required": true
      },
      {
        "name": "quantity",
        "type": "number",
        "required": true,
        "default": 0
      },
      {
        "name": "sku",
        "type": "string",
        "required": true
      },
      {
        "name": "category",
        "type": "enum",
        "values": [
          "electronics",
          "clothing",
          "books",
          "home",
          "sports",
          "other"
        ]
      },
      {
        "name": "status",
        "type": "enum",
        "values": [
          "active",
          "inactive",
          "discontinued"
        ]
      },
      {
        "name": "lowStockThreshold",
        "type": "number",
        "default": 10
      },
      {
        "name": "supplier",
        "type": "string"
      },
      {
        "name": "createdAt",
        "type": "date"
      },
      {
        "name": "updatedAt",
        "type": "date"
      }
    ]
  },
  "traits": [
    {
      "name": "ProductStatus",
      "category": "status",
      "linkedEntity": "Product",
      "stateMachine": {
        "states": [
          {
            "name": "Active",
            "isInitial": true
          },
          {
            "name": "LowStock",
            "isInitial": false
          },
          {
            "name": "OutOfStock",
            "isInitial": false
          },
          {
            "name": "Inactive",
            "isInitial": false
          },
          {
            "name": "Discontinued",
            "isInitial": false
          }
        ],
        "events": [
          {
            "key": "CHECK_STOCK",
            "name": "Check Stock"
          },
          {
            "key": "RESTOCK",
            "name": "Restock"
          },
          {
            "key": "DEACTIVATE",
            "name": "Deactivate"
          },
          {
            "key": "ACTIVATE",
            "name": "Activate"
          },
          {
            "key": "DISCONTINUE",
            "name": "Discontinue"
          },
          {
            "key": "STOCK_DEPLETED",
            "name": "Stock Depleted"
          },
          {
            "key": "STOCK_LOW",
            "name": "Stock Low"
          }
        ],
        "transitions": [
          {
            "from": "Active",
            "to": "LowStock",
            "event": "STOCK_LOW",
            "effects": [
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Product stock is running low",
                  "variant": "warning"
                }
              ]
            ]
          },
          {
            "from": "Active",
            "to": "OutOfStock",
            "event": "STOCK_DEPLETED",
            "effects": [
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Product is out of stock",
                  "variant": "danger"
                }
              ]
            ]
          },
          {
            "from": "LowStock",
            "to": "Active",
            "event": "RESTOCK",
            "effects": [
              [
                "persist",
                "update",
                "Product",
                "@entity"
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Product restocked successfully",
                  "variant": "success"
                }
              ]
            ]
          },
          {
            "from": "LowStock",
            "to": "OutOfStock",
            "event": "STOCK_DEPLETED",
            "effects": [
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Product is now out of stock",
                  "variant": "danger"
                }
              ]
            ]
          },
          {
            "from": "OutOfStock",
            "to": "Active",
            "event": "RESTOCK",
            "effects": [
              [
                "persist",
                "update",
                "Product",
                "@entity"
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Product back in stock",
                  "variant": "success"
                }
              ]
            ]
          },
          {
            "from": "Active",
            "to": "Inactive",
            "event": "DEACTIVATE",
            "effects": [
              [
                "persist",
                "update",
                "Product",
                {
                  "status": "inactive"
                }
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Product deactivated",
                  "variant": "secondary"
                }
              ]
            ]
          },
          {
            "from": "LowStock",
            "to": "Inactive",
            "event": "DEACTIVATE",
            "effects": [
              [
                "persist",
                "update",
                "Product",
                {
                  "status": "inactive"
                }
              ]
            ]
          },
          {
            "from": "Inactive",
            "to": "Active",
            "event": "ACTIVATE",
            "effects": [
              [
                "persist",
                "update",
                "Product",
                {
                  "status": "active"
                }
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Product activated",
                  "variant": "success"
                }
              ]
            ]
          },
          {
            "from": "Active",
            "to": "Discontinued",
            "event": "DISCONTINUE",
            "effects": [
              [
                "persist",
                "update",
                "Product",
                {
                  "status": "discontinued"
                }
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "notification",
                  "message": "Product discontinued",
                  "variant": "danger"
                }
              ]
            ]
          },
          {
            "from": "LowStock",
            "to": "Discontinued",
            "event": "DISCONTINUE",
            "effects": [
              [
                "persist",
                "update",
                "Product",
                {
                  "status": "discontinued"
                }
              ]
            ]
          },
          {
            "from": "Inactive",
            "to": "Discontinued",
            "event": "DISCONTINUE",
            "effects": [
              [
                "persist",
                "update",
                "Product",
                {
                  "status": "discontinued"
                }
              ]
            ]
          }
        ]
      }
    },
    {
