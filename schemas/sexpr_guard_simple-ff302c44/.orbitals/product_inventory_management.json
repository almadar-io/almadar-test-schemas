                    },
                    {
                      "label": "Restock",
                      "event": "RESTOCK",
                      "placement": "menu"
                    },
                    {
                      "label": "Delete",
                      "event": "DELETE",
                      "placement": "menu",
                      "isDestructive": true
                    }
                  ]
                }
              ]
            ]
          },
