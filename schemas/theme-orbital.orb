                    "title": "Filter Patterns",
                    "subtitle": "Search and filter components"
                  }],
                  ["render-ui", "sidebar", {
                    "type": "search-input",
                    "placeholder": "Search items...",
                    "entity": "SearchableItem"
                  }],
                  ["render-ui", "center", {
                    "type": "filter-group",
                    "entity": "SearchableItem",
                    "filters": [
                      { "field": "category", "label": "Category", "filterType": "select", "options": ["tech", "design", "marketing", "sales"] },
                      { "field": "priority", "label": "Priority", "filterType": "select", "options": ["low", "medium", "high"] }
                    ]
                  }]
                ]
              },
              {
                "from": "idle",
                "event": "SEARCH",
                "to": "searching"
              },
              {
                "from": "idle",
                "event": "FILTER",
                "to": "filtered"
              },
              {
                "from": "searching",
                "event": "CLEAR",
                "to": "idle"
              },
              {
                "from": "filtered",
                "event": "CLEAR",
                "to": "idle"
              }
            ]
          }
        }
      ],
      "pages": [
