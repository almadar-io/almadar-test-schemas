                ]
              },
              {
                "from": "closed",
                "event": "OPEN",
                "to": "open",
                "effects": [
                  ["render-ui", "drawer", {
                    "type": "detail-panel",
                    "title": "Drawer Content",
                    "entity": "ModalItem",
                    "fields": ["title", "content"],
                    "actions": [
                      { "label": "Close", "event": "CLOSE" }
                    ]
                  }]
                ]
              },
              {
                "from": "open",
                "event": "CLOSE",
                "to": "closed"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ModalPage",
          "path": "/modals/modal",
          "traits": [
            { "ref": "ModalDemo", "linkedEntity": "ModalItem" }
          ]
        },
        {
          "name": "DrawerPage",
          "path": "/modals/drawer",
          "traits": [
            { "ref": "DrawerDemo", "linkedEntity": "ModalItem" }
          ]
        }
      ]
    },
    {
      "name": "AccordionAlertShowcase",
      "entity": {
        "name": "ContentItem",
        "persistence": "runtime",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "title", "type": "string", "required": true },
          { "name": "content", "type": "string" },
          { "name": "isExpanded", "type": "boolean", "default": false }
        ]
      },
      "traits": [
        {
          "name": "AccordionDemo",
          "category": "interaction",
          "linkedEntity": "ContentItem",
          "stateMachine": {
            "states": [
              { "name": "viewing", "isInitial": true }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "TOGGLE", "name": "Toggle Section", "payload": [{ "name": "id", "type": "string" }] }
            ],
            "transitions": [
              {
                "from": "viewing",
                "event": "INIT",
                "to": "viewing",
                "effects": [
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Accordion Pattern",
                    "subtitle": "Collapsible content sections"
                  }],
                  ["render-ui", "center", {
                    "type": "accordion",
                    "items": [
                      { "id": "section1", "title": "Section 1", "content": "Content for section 1" },
                      { "id": "section2", "title": "Section 2", "content": "Content for section 2" },
                      { "id": "section3", "title": "Section 3", "content": "Content for section 3" }
                    ]
                  }]
                ]
              },
              {
                "from": "viewing",
                "event": "TOGGLE",
                "to": "viewing"
              }
            ]
          }
        },
        {
          "name": "AlertDemo",
          "category": "interaction",
          "linkedEntity": "ContentItem",
          "stateMachine": {
            "states": [
              { "name": "viewing", "isInitial": true }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "DISMISS", "name": "Dismiss Alert" }
            ],
            "transitions": [
              {
                "from": "viewing",
                "event": "INIT",
                "to": "viewing",
                "effects": [
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Alert Pattern",
                    "subtitle": "Alert message components"
                  }],
                  ["render-ui", "center", {
                    "type": "alert",
                    "variant": "info",
                    "title": "Information",
                    "message": "This is an informational alert message."
                  }]
                ]
              },
              {
                "from": "viewing",
                "event": "DISMISS",
                "to": "viewing"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "AccordionPage",
          "path": "/molecules/accordion",
          "traits": [
            { "ref": "AccordionDemo", "linkedEntity": "ContentItem" }
          ]
        },
        {
          "name": "AlertPage",
          "path": "/molecules/alert",
          "traits": [
            { "ref": "AlertDemo", "linkedEntity": "ContentItem" }
          ]
        }
      ]
    },
    {
      "name": "GameShowcase",
      "entity": {
        "name": "GameState",
        "persistence": "runtime",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "score", "type": "number", "default": 0 },
          { "name": "lives", "type": "number", "default": 3 },
          { "name": "level", "type": "number", "default": 1 },
          { "name": "isPaused", "type": "boolean", "default": false },
          { "name": "isGameOver", "type": "boolean", "default": false }
        ]
      },
      "traits": [
        {
          "name": "GameDemo",
          "category": "interaction",
          "linkedEntity": "GameState",
          "stateMachine": {
            "states": [
              { "name": "menu", "isInitial": true },
              { "name": "playing" },
              { "name": "paused" },
              { "name": "gameOver" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "START", "name": "Start Game" },
              { "key": "PAUSE", "name": "Pause Game" },
              { "key": "RESUME", "name": "Resume Game" },
              { "key": "GAME_OVER", "name": "Game Over" },
              { "key": "RESTART", "name": "Restart Game" }
            ],
            "transitions": [
              {
                "from": "menu",
                "event": "INIT",
                "to": "menu",
                "effects": [
                  ["render-ui", "main", {
                    "type": "game-menu",
                    "title": "Game Patterns Demo",
                    "options": [
                      { "label": "Start Game", "event": "START" },
                      { "label": "Settings", "event": "SETTINGS" }
                    ]
                  }]
                ]
              },
              {
                "from": "menu",
                "event": "START",
                "to": "playing",
                "effects": [
                  ["render-ui", "main", {
                    "type": "game-canvas",
                    "width": 800,
                    "height": 600
                  }],
                  ["render-ui", "hud-top", {
                    "type": "game-hud",
                    "stats": [
                      { "label": "Score", "value": "@entity.score" },
                      { "label": "Lives", "value": "@entity.lives" },
                      { "label": "Level", "value": "@entity.level" }
                    ]
                  }],
                  ["render-ui", "hud-bottom", {
                    "type": "game-controls",
                    "layout": "buttons",
                    "position": "bottom-center",
                    "controls": [
                      { "id": "left", "label": "Left", "event": "MOVE_LEFT" },
                      { "id": "right", "label": "Right", "event": "MOVE_RIGHT" },
                      { "id": "jump", "label": "Jump", "event": "JUMP" },
                      { "id": "pause", "label": "Pause", "event": "PAUSE" }
                    ]
                  }]
                ]
              },
              {
                "from": "playing",
                "event": "PAUSE",
                "to": "paused",
                "effects": [
                  ["render-ui", "overlay", {
                    "type": "game-pause-overlay",
                    "title": "Paused",
                    "options": [
                      { "label": "Resume", "event": "RESUME" },
                      { "label": "Restart", "event": "RESTART" },
                      { "label": "Quit", "event": "INIT" }
                    ]
                  }]
                ]
              },
              {
                "from": "paused",
                "event": "RESUME",
                "to": "playing"
              },
              {
                "from": "playing",
                "event": "GAME_OVER",
                "to": "gameOver",
                "effects": [
                  ["render-ui", "overlay", {
                    "type": "game-over-screen",
                    "title": "Game Over",
                    "currentScore": "@entity.score",
                    "actions": [
                      { "label": "Play Again", "event": "RESTART" },
                      { "label": "Main Menu", "event": "INIT" }
                    ]
                  }]
                ]
              },
              {
                "from": "gameOver",
                "event": "RESTART",
                "to": "playing"
              },
              {
                "from": "paused",
                "event": "RESTART",
                "to": "playing"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "GamePage",
          "path": "/game",
          "traits": [
            { "ref": "GameDemo", "linkedEntity": "GameState" }
          ]
        }
      ]
    },
    {
      "name": "LayoutShowcase",
      "entity": {
        "name": "LayoutDemo",
        "persistence": "runtime",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "layoutType", "type": "enum", "values": ["split", "grid", "flex", "box"], "default": "flex" }
        ]
      },
      "traits": [
        {
          "name": "LayoutViewer",
          "category": "interaction",
          "linkedEntity": "LayoutDemo",
          "stateMachine": {
            "states": [
              { "name": "viewing", "isInitial": true }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" }
            ],
            "transitions": [
              {
                "from": "viewing",
                "event": "INIT",
                "to": "viewing",
                "effects": [
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Layout Patterns",
                    "subtitle": "Flexible layout primitives for building UIs"
                  }],
                  ["render-ui", "sidebar", {
                    "type": "vstack",
                    "gap": "lg",
                    "children": [
                      {
                        "type": "heading",
                        "content": "VStack (Vertical)",
                        "level": 3
                      },
                      {
                        "type": "box",
                        "p": "md",
                        "bg": "surface",
                        "border": "default",
                        "radius": "md",
                        "children": [
                          {
                            "type": "vstack",
                            "gap": "sm",
                            "children": [
                              { "type": "box", "p": "sm", "bg": "primary", "children": [{ "type": "text", "content": "Item 1" }] },
                              { "type": "box", "p": "sm", "bg": "primary", "children": [{ "type": "text", "content": "Item 2" }] },
                              { "type": "box", "p": "sm", "bg": "primary", "children": [{ "type": "text", "content": "Item 3" }] }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "HStack (Horizontal)",
                        "level": 3
                      },
                      {
                        "type": "box",
                        "p": "md",
                        "bg": "surface",
                        "border": "default",
                        "radius": "md",
                        "children": [
                          {
                            "type": "hstack",
                            "gap": "sm",
                            "children": [
                              { "type": "box", "p": "sm", "bg": "secondary", "children": [{ "type": "text", "content": "A" }] },
                              { "type": "box", "p": "sm", "bg": "secondary", "children": [{ "type": "text", "content": "B" }] },
                              { "type": "box", "p": "sm", "bg": "secondary", "children": [{ "type": "text", "content": "C" }] }
                            ]
                          }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Center",
                        "level": 3
                      },
                      {
                        "type": "box",
                        "p": "md",
                        "bg": "surface",
                        "border": "default",
                        "radius": "md",
                        "children": [
                          {
                            "type": "center",
                            "minHeight": "100px",
                            "children": [
                              { "type": "text", "content": "Centered Content", "weight": "bold" }
                            ]
                          }
                        ]
                      }
                    ]
                  }],
                  ["render-ui", "center", {
                    "type": "vstack",
                    "gap": "lg",
                    "children": [
                      {
                        "type": "heading",
                        "content": "Grid Layout",
                        "level": 3
                      },
                      {
                        "type": "grid",
                        "cols": 3,
                        "gap": "md",
                        "children": [
                          { "type": "card", "title": "Card 1", "padding": "md", "children": [{ "type": "text", "content": "Grid cell 1" }] },
                          { "type": "card", "title": "Card 2", "padding": "md", "children": [{ "type": "text", "content": "Grid cell 2" }] },
                          { "type": "card", "title": "Card 3", "padding": "md", "children": [{ "type": "text", "content": "Grid cell 3" }] },
                          { "type": "card", "title": "Card 4", "padding": "md", "children": [{ "type": "text", "content": "Grid cell 4" }] },
                          { "type": "card", "title": "Card 5", "padding": "md", "children": [{ "type": "text", "content": "Grid cell 5" }] },
                          { "type": "card", "title": "Card 6", "padding": "md", "children": [{ "type": "text", "content": "Grid cell 6" }] }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Box with Styling",
                        "level": 3
                      },
                      {
                        "type": "hstack",
                        "gap": "md",
                        "children": [
                          { "type": "box", "p": "lg", "bg": "surface", "border": "default", "shadow": "sm", "radius": "md", "children": [{ "type": "text", "content": "Surface Box" }] },
                          { "type": "box", "p": "lg", "bg": "muted", "border": "default", "shadow": "md", "radius": "lg", "children": [{ "type": "text", "content": "Muted Box" }] },
                          { "type": "box", "p": "lg", "bg": "card", "border": "default", "shadow": "lg", "radius": "xl", "children": [{ "type": "text", "content": "Card Box" }] }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Spacer Demo",
                        "level": 3
                      },
                      {
                        "type": "box",
                        "p": "md",
                        "bg": "surface",
                        "border": "default",
                        "radius": "md",
                        "children": [
                          {
                            "type": "hstack",
                            "gap": "sm",
                            "children": [
                              { "type": "button", "label": "Left", "variant": "primary" },
                              { "type": "spacer", "size": "flex" },
                              { "type": "button", "label": "Right", "variant": "secondary" }
                            ]
                          }
                        ]
                      }
                    ]
                  }]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "LayoutPage",
          "path": "/layouts",
          "traits": [
            { "ref": "LayoutViewer", "linkedEntity": "LayoutDemo" }
          ]
        }
      ]
    },
    {
      "name": "ContainerShowcase",
      "entity": {
        "name": "ContainerDemo",
        "persistence": "runtime",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "isOpen", "type": "boolean", "default": false }
        ]
      },
      "traits": [
        {
          "name": "ContainerViewer",
          "category": "interaction",
          "linkedEntity": "ContainerDemo",
          "stateMachine": {
            "states": [
              { "name": "viewing", "isInitial": true },
              { "name": "modalOpen" },
              { "name": "drawerOpen" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "OPEN_MODAL", "name": "Open Modal" },
              { "key": "OPEN_DRAWER", "name": "Open Drawer" },
              { "key": "CLOSE", "name": "Close" },
              { "key": "CONFIRM", "name": "Confirm" },
              { "key": "CANCEL", "name": "Cancel" }
            ],
            "transitions": [
              {
                "from": "viewing",
                "event": "INIT",
                "to": "viewing",
                "effects": [
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Container Patterns",
                    "subtitle": "Modal, Drawer, and Container components",
                    "actions": [
                      { "label": "Open Modal", "event": "OPEN_MODAL", "variant": "primary" },
                      { "label": "Open Drawer", "event": "OPEN_DRAWER", "variant": "secondary" }
                    ]
                  }],
                  ["render-ui", "center", {
                    "type": "vstack",
                    "gap": "lg",
                    "children": [
                      {
                        "type": "heading",
                        "content": "Container Patterns",
                        "level": 3
                      },
                      {
                        "type": "text",
                        "content": "Click the buttons above to see Modal and Drawer containers in action."
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Card Container",
                        "level": 3
                      },
                      {
                        "type": "card",
                        "title": "Card Container Example",
                        "subtitle": "With header and footer",
                        "padding": "lg",
                        "shadow": "md",
                        "children": [
                          { "type": "text", "content": "This is the card body content. Cards are great for grouping related information together." }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Max-Width Container",
                        "level": 3
                      },
                      {
                        "type": "container",
                        "maxWidth": "md",
                        "padding": "lg",
                        "children": [
                          { "type": "box", "p": "md", "bg": "surface", "border": "default", "radius": "md", "children": [
                            { "type": "text", "content": "This content is constrained to a medium max-width container." }
                          ]}
                        ]
                      }
                    ]
                  }]
                ]
              },
              {
                "from": "viewing",
                "event": "OPEN_MODAL",
                "to": "modalOpen",
                "effects": [
                  ["render-ui", "modal", {
                    "type": "confirm-dialog",
                    "title": "Confirm Action",
                    "message": "This is a modal dialog. Do you want to proceed?",
                    "confirmText": "Yes, Proceed",
                    "cancelText": "Cancel",
                    "variant": "default"
                  }]
                ]
              },
              {
                "from": "modalOpen",
                "event": "CONFIRM",
                "to": "viewing",
                "effects": [
                  ["notify", "success", "Action confirmed successfully!"]
                ]
              },
              {
                "from": "modalOpen",
                "event": "CANCEL",
                "to": "viewing"
              },
              {
                "from": "modalOpen",
                "event": "CLOSE",
                "to": "viewing"
              },
              {
                "from": "viewing",
                "event": "OPEN_DRAWER",
                "to": "drawerOpen",
                "effects": [
                  ["render-ui", "drawer", {
                    "type": "drawer",
                    "title": "Drawer Panel",
                    "position": "right",
                    "width": "400px"
                  }]
                ]
              },
              {
                "from": "drawerOpen",
                "event": "CLOSE",
                "to": "viewing"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ContainerPage",
          "path": "/containers",
          "traits": [
            { "ref": "ContainerViewer", "linkedEntity": "ContainerDemo" }
          ]
        }
      ]
    }
  ]
}
