{
  "name": "Theme Kitchen Sink",
  "version": "1.0.0",
  "description": "Comprehensive kitchen sink showcasing all themed components organized by atomic design",
  "orbitals": [
    {
      "name": "AtomsShowcase",
      "theme": {
        "name": "ocean",
        "tokens": {
          "colors": {
            "primary": "#0ea5e9",
            "primary-hover": "#0284c7",
            "primary-active": "#0369a1",
            "primary-foreground": "#ffffff",
            "secondary": "#64748b",
            "secondary-hover": "#475569",
            "secondary-active": "#334155",
            "secondary-foreground": "#ffffff",
            "accent": "#06b6d4",
            "accent-foreground": "#ffffff",
            "background": "#ffffff",
            "foreground": "#0c4a6e",
            "surface": "#f8fafc",
            "surface-hover": "#f1f5f9",
            "card": "#ffffff",
            "card-foreground": "#0c4a6e",
            "muted": "#f0f9ff",
            "muted-foreground": "#64748b",
            "border": "#e2e8f0",
            "ring": "#0ea5e9",
            "success": "#22c55e",
            "success-foreground": "#ffffff",
            "warning": "#f59e0b",
            "warning-foreground": "#ffffff",
            "error": "#ef4444",
            "error-foreground": "#ffffff",
            "info": "#3b82f6",
            "info-foreground": "#ffffff"
          },
          "radii": {
            "sm": "4px",
            "md": "8px",
            "lg": "12px",
            "xl": "16px",
            "full": "9999px"
          },
          "shadows": {
            "sm": "0 1px 3px rgba(14, 165, 233, 0.1)",
            "main": "0 4px 6px rgba(14, 165, 233, 0.15)",
            "lg": "0 10px 15px rgba(14, 165, 233, 0.15)",
            "hover": "0 8px 25px rgba(14, 165, 233, 0.2)",
            "active": "0 2px 4px rgba(14, 165, 233, 0.1)"
          }
        },
        "variants": {
          "dark": {
            "colors": {
              "primary": "#38bdf8",
              "primary-hover": "#7dd3fc",
              "primary-foreground": "#0c4a6e",
              "secondary": "#94a3b8",
              "secondary-foreground": "#0f172a",
              "background": "#0c4a6e",
              "foreground": "#f0f9ff",
              "surface": "#164e63",
              "card": "#164e63",
              "card-foreground": "#f0f9ff",
              "muted": "#164e63",
              "muted-foreground": "#94a3b8",
              "border": "#155e75",
              "ring": "#38bdf8"
            }
          }
        }
      },
      "entity": {
        "name": "AtomDemo",
        "persistence": "runtime",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "label", "type": "string", "required": true },
          { "name": "variant", "type": "string" },
          { "name": "size", "type": "enum", "values": ["sm", "md", "lg"], "default": "md" },
          { "name": "isDisabled", "type": "boolean", "default": false }
        ]
      },
      "traits": [
        {
          "name": "AtomsViewer",
          "category": "interaction",
          "linkedEntity": "AtomDemo",
          "stateMachine": {
            "states": [
              { "name": "viewing", "isInitial": true },
              { "name": "alertShown" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SHOW_ALERT", "name": "Show Alert" },
              { "key": "DISMISS", "name": "Dismiss" }
            ],
            "transitions": [
              {
                "from": "viewing",
                "event": "INIT",
                "to": "viewing",
                "effects": [
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Atoms Showcase",
                    "subtitle": "Basic building blocks: buttons, badges, inputs, icons, avatars",
                    "actions": [
                      { "label": "Show Alert", "event": "SHOW_ALERT", "variant": "secondary" }
                    ]
                  }],
                  ["render-ui", "sidebar", {
                    "type": "vstack",
                    "gap": "md",
                    "children": [
                      {
                        "type": "heading",
                        "content": "Button Variants",
                        "level": 3
                      },
                      {
                        "type": "hstack",
                        "gap": "sm",
                        "children": [
                          { "type": "button", "label": "Primary", "variant": "primary" },
                          { "type": "button", "label": "Secondary", "variant": "secondary" },
                          { "type": "button", "label": "Ghost", "variant": "ghost" }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Badge Examples",
                        "level": 3
                      },
                      {
                        "type": "hstack",
                        "gap": "sm",
                        "children": [
                          { "type": "badge", "label": "Active", "variant": "success" },
                          { "type": "badge", "label": "Pending", "variant": "warning" },
                          { "type": "badge", "label": "Inactive", "variant": "default" }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Avatar Sizes",
                        "level": 3
                      },
                      {
                        "type": "hstack",
                        "gap": "sm",
                        "align": "center",
                        "children": [
                          { "type": "avatar", "name": "John Doe", "size": "sm" },
                          { "type": "avatar", "name": "Jane Smith", "size": "md" },
                          { "type": "avatar", "name": "Bob Wilson", "size": "lg" }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Icons",
                        "level": 3
                      },
                      {
                        "type": "hstack",
                        "gap": "md",
                        "children": [
                          { "type": "icon", "name": "home", "size": "md" },
                          { "type": "icon", "name": "settings", "size": "md" },
                          { "type": "icon", "name": "user", "size": "md" },
                          { "type": "icon", "name": "search", "size": "md" },
                          { "type": "icon", "name": "bell", "size": "md" }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Progress & Spinner",
                        "level": 3
                      },
                      {
                        "type": "vstack",
                        "gap": "sm",
                        "children": [
                          { "type": "progress-bar", "value": 65, "variant": "primary", "showLabel": true },
                          { "type": "hstack", "gap": "md", "align": "center", "children": [
                            { "type": "spinner", "size": "sm" },
                            { "type": "text", "content": "Loading...", "color": "muted" }
                          ]}
                        ]
                      }
                    ]
                  }],
                  ["render-ui", "center", {
                    "type": "vstack",
                    "gap": "md",
                    "children": [
                      {
                        "type": "heading",
                        "content": "Form Inputs",
                        "level": 3
                      },
                      {
                        "type": "vstack",
                        "gap": "sm",
                        "children": [
                          { "type": "input", "placeholder": "Text input example", "type": "text" },
                          { "type": "textarea", "placeholder": "Textarea for longer content...", "rows": 3 },
                          { "type": "select", "placeholder": "Select an option", "options": [
                            { "value": "opt1", "label": "Option 1" },
                            { "value": "opt2", "label": "Option 2" },
                            { "value": "opt3", "label": "Option 3" }
                          ]}
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Checkbox & Radio & Switch",
                        "level": 3
                      },
                      {
                        "type": "vstack",
                        "gap": "sm",
                        "children": [
                          { "type": "checkbox", "label": "Accept terms and conditions", "checked": true },
                          { "type": "checkbox", "label": "Subscribe to newsletter", "checked": false },
                          { "type": "radio", "label": "Option A", "name": "demo-radio", "checked": true },
                          { "type": "radio", "label": "Option B", "name": "demo-radio", "checked": false },
                          { "type": "switch", "label": "Enable notifications", "checked": true }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Typography",
                        "level": 3
                      },
                      {
                        "type": "vstack",
                        "gap": "xs",
                        "children": [
                          { "type": "heading", "content": "Heading 1", "level": 1 },
                          { "type": "heading", "content": "Heading 2", "level": 2 },
                          { "type": "heading", "content": "Heading 3", "level": 3 },
                          { "type": "text", "content": "Body text with default styling.", "variant": "body" },
                          { "type": "text", "content": "Caption text in muted color.", "variant": "caption", "color": "muted" }
                        ]
                      }
                    ]
                  }]
                ]
              },
              {
                "from": "viewing",
                "event": "SHOW_ALERT",
                "to": "alertShown",
                "effects": [
                  ["render-ui", "toast", {
                    "type": "alert",
                    "variant": "info",
                    "title": "Information",
                    "message": "This is an alert component demonstration."
                  }]
                ]
              },
              {
                "from": "alertShown",
                "event": "DISMISS",
                "to": "viewing"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "AtomsPage",
          "path": "/atoms",
          "traits": [
            { "ref": "AtomsViewer", "linkedEntity": "AtomDemo" }
          ]
        }
      ]
    },
    {
      "name": "MoleculesShowcase",
      "entity": {
        "name": "MoleculeDemo",
        "persistence": "runtime",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "name", "type": "string", "required": true },
          { "name": "category", "type": "string" },
          { "name": "searchTerm", "type": "string" }
        ]
      },
      "traits": [
        {
          "name": "MoleculesViewer",
          "category": "interaction",
          "linkedEntity": "MoleculeDemo",
          "stateMachine": {
            "states": [
              { "name": "viewing", "isInitial": true },
              { "name": "searching" },
              { "name": "modalOpen" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SEARCH", "name": "Search", "payload": [{ "name": "term", "type": "string" }] },
              { "key": "CLEAR", "name": "Clear Search" },
              { "key": "OPEN_MODAL", "name": "Open Modal" },
              { "key": "CLOSE", "name": "Close" },
              { "key": "TAB_CHANGE", "name": "Tab Change", "payload": [{ "name": "tabId", "type": "string" }] },
              { "key": "TOGGLE", "name": "Toggle Section", "payload": [{ "name": "id", "type": "string" }] }
            ],
            "transitions": [
              {
                "from": "viewing",
                "event": "INIT",
                "to": "viewing",
                "effects": [
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Molecules Showcase",
                    "subtitle": "Composite components built from atoms",
                    "actions": [
                      { "label": "Open Modal", "event": "OPEN_MODAL", "variant": "primary" }
                    ]
                  }],
                  ["render-ui", "sidebar", {
                    "type": "vstack",
                    "gap": "lg",
                    "children": [
                      {
                        "type": "heading",
                        "content": "Search Input",
                        "level": 3
                      },
                      {
                        "type": "search-input",
                        "placeholder": "Search molecules...",
                        "clearable": true
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Tabs Navigation",
                        "level": 3
                      },
                      {
                        "type": "tabs",
                        "items": [
                          { "id": "overview", "label": "Overview" },
                          { "id": "details", "label": "Details" },
                          { "id": "settings", "label": "Settings" }
                        ],
                        "activeTab": "overview"
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Breadcrumb",
                        "level": 3
                      },
                      {
                        "type": "breadcrumb",
                        "items": [
                          { "label": "Home", "href": "/" },
                          { "label": "Components", "href": "/components" },
                          { "label": "Molecules" }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Pagination",
                        "level": 3
                      },
                      {
                        "type": "pagination",
                        "currentPage": 3,
                        "totalPages": 10,
                        "showTotal": true,
                        "totalItems": 95
                      }
                    ]
                  }],
                  ["render-ui", "center", {
                    "type": "vstack",
                    "gap": "lg",
                    "children": [
                      {
                        "type": "heading",
                        "content": "Accordion",
                        "level": 3
                      },
                      {
                        "type": "accordion",
                        "items": [
                          { "id": "acc1", "title": "What are molecules?", "content": "Molecules are composite UI components built from atoms. They combine simple elements to create more complex, reusable patterns." },
                          { "id": "acc2", "title": "When to use molecules?", "content": "Use molecules when you need to combine multiple atoms into a cohesive unit that serves a specific purpose, like a search bar or filter group." },
                          { "id": "acc3", "title": "Examples of molecules", "content": "SearchInput, FilterGroup, Tabs, Breadcrumb, Pagination, Accordion, Modal, Drawer, Toast, and Tooltip." }
                        ],
                        "multiple": true
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Alerts",
                        "level": 3
                      },
                      {
                        "type": "vstack",
                        "gap": "sm",
                        "children": [
                          { "type": "alert", "variant": "info", "title": "Information", "message": "This is an informational alert." },
                          { "type": "alert", "variant": "success", "title": "Success", "message": "Operation completed successfully!" },
                          { "type": "alert", "variant": "warning", "title": "Warning", "message": "Please review before proceeding." },
                          { "type": "alert", "variant": "error", "title": "Error", "message": "Something went wrong." }
                        ]
                      },
                      {
                        "type": "divider",
                        "orientation": "horizontal"
                      },
                      {
                        "type": "heading",
                        "content": "Wizard Progress",
                        "level": 3
                      },
                      {
                        "type": "wizard-progress",
                        "steps": [
                          { "id": "step1", "title": "Account" },
                          { "id": "step2", "title": "Profile" },
                          { "id": "step3", "title": "Review" },
                          { "id": "step4", "title": "Complete" }
                        ],
                        "currentStep": 1
                      }
                    ]
                  }]
                ]
              },
              {
                "from": "viewing",
                "event": "SEARCH",
                "to": "searching"
              },
              {
                "from": "searching",
                "event": "CLEAR",
                "to": "viewing"
              },
              {
                "from": "viewing",
                "event": "OPEN_MODAL",
                "to": "modalOpen",
                "effects": [
                  ["render-ui", "modal", {
                    "type": "vstack",
                    "gap": "md",
                    "children": [
                      { "type": "heading", "content": "Modal Example", "level": 3 },
                      { "type": "text", "content": "This is modal content rendered via the closed circuit pattern. Click outside or press Escape to close." }
                    ]
                  }]
                ]
              },
              {
                "from": "modalOpen",
                "event": "CLOSE",
                "to": "viewing"
              },
              {
                "from": "viewing",
                "event": "TAB_CHANGE",
                "to": "viewing"
              },
              {
                "from": "viewing",
                "event": "TOGGLE",
                "to": "viewing"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "MoleculesPage",
          "path": "/molecules",
          "traits": [
            { "ref": "MoleculesViewer", "linkedEntity": "MoleculeDemo" }
          ]
        }
      ]
    },
    {
      "name": "OrganismsShowcase",
      "entity": {
        "name": "Product",
        "persistence": "persistent",
        "collection": "products",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "name", "type": "string", "required": true },
          { "name": "description", "type": "string" },
          { "name": "price", "type": "number", "required": true },
          { "name": "stock", "type": "number", "default": 0 },
          { "name": "category", "type": "enum", "values": ["electronics", "clothing", "food", "other"], "default": "other" },
          { "name": "status", "type": "enum", "values": ["active", "draft", "archived"], "default": "draft" },
          { "name": "createdAt", "type": "timestamp" }
        ]
      },
      "traits": [
        {
          "name": "ProductCRUD",
          "category": "interaction",
          "linkedEntity": "Product",
          "stateMachine": {
            "states": [
              { "name": "listing", "isInitial": true },
              { "name": "viewing" },
              { "name": "creating" },
              { "name": "editing" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "VIEW", "name": "View Product", "payload": [{ "name": "id", "type": "string", "required": true }] },
              { "key": "CREATE", "name": "Create Product" },
              { "key": "EDIT", "name": "Edit Product" },
              { "key": "SAVE", "name": "Save" },
              { "key": "CANCEL", "name": "Cancel" },
              { "key": "BACK", "name": "Go Back" },
              { "key": "DELETE", "name": "Delete Product", "payload": [{ "name": "id", "type": "string", "required": true }] }
            ],
            "transitions": [
              {
                "from": "listing",
                "event": "INIT",
                "to": "listing",
                "effects": [
                  ["fetch", "Product"],
                  ["render-ui", "main", {
                    "type": "entity-table",
                    "entity": "Product",
                    "columns": ["name", "price", "stock", "category", "status"],
                    "itemActions": [
                      { "event": "VIEW", "label": "View" },
                      { "event": "EDIT", "label": "Edit" },
                      { "event": "DELETE", "label": "Delete" }
                    ]
                  }]
                ]
              },
              {
                "from": "listing",
                "event": "VIEW",
                "to": "viewing",
                "effects": [
                  ["fetch", "Product", "@payload.id"],
                  ["render-ui", "main", {
                    "type": "entity-detail",
                    "entity": "Product",
                    "fields": ["name", "description", "price", "stock", "category", "status"]
                  }]
                ]
              },
              {
                "from": "listing",
                "event": "CREATE",
                "to": "creating",
                "effects": [
                  ["render-ui", "main", {
                    "type": "form",
                    "entity": "Product",
                    "fields": [
                      { "name": "name", "label": "Product Name", "required": true },
                      { "name": "description", "label": "Description", "type": "textarea" },
                      { "name": "price", "label": "Price", "type": "number", "required": true },
                      { "name": "stock", "label": "Stock", "type": "number" },
                      { "name": "category", "label": "Category", "type": "select", "options": [
                        { "value": "electronics", "label": "Electronics" },
                        { "value": "clothing", "label": "Clothing" },
                        { "value": "food", "label": "Food" },
                        { "value": "other", "label": "Other" }
                      ]},
                      { "name": "status", "label": "Status", "type": "select", "options": [
                        { "value": "active", "label": "Active" },
                        { "value": "draft", "label": "Draft" },
                        { "value": "archived", "label": "Archived" }
                      ]}
                    ]
                  }]
                ]
              },
              {
                "from": "creating",
                "event": "SAVE",
                "to": "listing",
                "effects": [
                  ["persist", "create", "Product", "@entity"],
                  ["notify", "success", "Product created successfully"]
                ]
              },
              {
                "from": "creating",
                "event": "CANCEL",
                "to": "listing"
              },
              {
                "from": "viewing",
                "event": "EDIT",
                "to": "editing",
                "effects": [
                  ["render-ui", "main", {
                    "type": "form",
                    "entity": "Product",
                    "mode": "edit",
                    "fields": [
                      { "name": "name", "label": "Product Name", "required": true },
                      { "name": "description", "label": "Description", "type": "textarea" },
                      { "name": "price", "label": "Price", "type": "number", "required": true },
                      { "name": "stock", "label": "Stock", "type": "number" },
                      { "name": "category", "label": "Category", "type": "select", "options": [
                        { "value": "electronics", "label": "Electronics" },
                        { "value": "clothing", "label": "Clothing" },
                        { "value": "food", "label": "Food" },
                        { "value": "other", "label": "Other" }
                      ]},
                      { "name": "status", "label": "Status", "type": "select", "options": [
                        { "value": "active", "label": "Active" },
                        { "value": "draft", "label": "Draft" },
                        { "value": "archived", "label": "Archived" }
                      ]}
                    ]
                  }]
                ]
              },
              {
                "from": "editing",
                "event": "SAVE",
                "to": "viewing",
                "effects": [
                  ["persist", "update", "Product", "@entity"],
                  ["notify", "success", "Product updated successfully"]
                ]
              },
              {
                "from": "editing",
                "event": "CANCEL",
                "to": "viewing"
              },
              {
                "from": "viewing",
                "event": "BACK",
                "to": "listing",
                "effects": [
                  ["navigate", "/organisms"]
                ]
              },
              {
                "from": "listing",
                "event": "DELETE",
                "to": "listing",
                "effects": [
                  ["persist", "delete", "Product", "@payload.id"],
                  ["notify", "info", "Product deleted"]
                ]
              }
            ]
          }
        },
        {
          "name": "CardGridViewer",
          "category": "interaction",
          "linkedEntity": "Product",
          "stateMachine": {
            "states": [
              { "name": "grid", "isInitial": true },
              { "name": "detail" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SELECT", "name": "Select Item", "payload": [{ "name": "id", "type": "string", "required": true }] },
              { "key": "BACK", "name": "Go Back" }
            ],
            "transitions": [
              {
                "from": "grid",
                "event": "INIT",
                "to": "grid",
                "effects": [
                  ["fetch", "Product"],
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Organisms - CardGrid",
                    "subtitle": "Visual card-based display of entities"
                  }],
                  ["render-ui", "sidebar", {
                    "type": "entity-cards",
                    "entity": "Product",
                    "fieldNames": ["name", "price", "category"],
                    "itemActions": [
                      { "event": "SELECT", "label": "View" }
                    ]
                  }]
                ]
              },
              {
                "from": "grid",
                "event": "SELECT",
                "to": "detail",
                "effects": [
                  ["fetch", "Product", "@payload.id"],
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Product Detail",
                    "showBack": true
                  }],
                  ["render-ui", "sidebar", {
                    "type": "entity-detail",
                    "entity": "Product",
                    "fields": ["name", "description", "price", "stock", "category", "status"]
                  }]
                ]
              },
              {
                "from": "detail",
                "event": "BACK",
                "to": "grid",
                "effects": [
