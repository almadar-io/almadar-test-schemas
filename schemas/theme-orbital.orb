    {
      "name": "WizardShowcase",
      "entity": {
        "name": "WizardData",
        "persistence": "runtime",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "step1Data", "type": "string" },
          { "name": "step2Data", "type": "string" },
          { "name": "step3Data", "type": "string" },
          { "name": "currentStep", "type": "number", "default": 0 }
        ]
      },
      "traits": [
        {
          "name": "WizardDemo",
          "category": "interaction",
          "linkedEntity": "WizardData",
          "stateMachine": {
            "states": [
              { "name": "step1", "isInitial": true },
              { "name": "step2" },
              { "name": "step3" },
              { "name": "complete", "isTerminal": true }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "NEXT", "name": "Next Step" },
              { "key": "BACK", "name": "Previous Step" },
              { "key": "COMPLETE", "name": "Complete Wizard" }
            ],
            "transitions": [
              {
                "from": "step1",
                "event": "INIT",
                "to": "step1",
                "effects": [
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Wizard Pattern",
                    "subtitle": "Multi-step form wizard"
                  }],
                  ["render-ui", "sidebar", {
                    "type": "wizard-progress",
                    "steps": [
                      { "id": "step1", "title": "Basic Info" },
                      { "id": "step2", "title": "Details" },
                      { "id": "step3", "title": "Review" }
                    ],
                    "currentStep": 0
                  }],
                  ["render-ui", "center", {
                    "type": "form",
                    "entity": "WizardData",
                    "fields": [
                      { "name": "step1Data", "label": "Step 1 Data", "required": true }
                    ]
                  }]
                ]
              },
              {
                "from": "step1",
                "event": "NEXT",
                "to": "step2",
                "effects": [
                  ["render-ui", "sidebar", {
                    "type": "wizard-progress",
                    "steps": [
                      { "id": "step1", "title": "Basic Info" },
                      { "id": "step2", "title": "Details" },
                      { "id": "step3", "title": "Review" }
                    ],
                    "currentStep": 1
                  }],
                  ["render-ui", "center", {
                    "type": "form",
                    "entity": "WizardData",
                    "fields": [
                      { "name": "step2Data", "label": "Step 2 Data", "required": true }
                    ]
                  }]
                ]
              },
              {
                "from": "step2",
                "event": "NEXT",
                "to": "step3",
                "effects": [
                  ["render-ui", "sidebar", {
                    "type": "wizard-progress",
                    "steps": [
                      { "id": "step1", "title": "Basic Info" },
                      { "id": "step2", "title": "Details" },
                      { "id": "step3", "title": "Review" }
                    ],
                    "currentStep": 2
                  }],
                  ["render-ui", "center", {
                    "type": "form",
                    "entity": "WizardData",
                    "fields": [
                      { "name": "step3Data", "label": "Step 3 Data" }
                    ]
                  }]
                ]
              },
              {
                "from": "step2",
                "event": "BACK",
                "to": "step1"
              },
              {
                "from": "step3",
                "event": "BACK",
                "to": "step2"
              },
              {
                "from": "step3",
                "event": "COMPLETE",
                "to": "complete",
                "effects": [
                  ["notify", "success", "Wizard completed!"]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "WizardPage",
          "path": "/wizard",
          "traits": [
            { "ref": "WizardDemo", "linkedEntity": "WizardData" }
          ]
        }
      ]
    },
