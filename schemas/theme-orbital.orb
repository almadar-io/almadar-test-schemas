    {
      "name": "TemplatesShowcase",
      "entity": {
        "name": "Project",
        "persistence": "persistent",
        "collection": "projects",
        "fields": [
          { "name": "id", "type": "string", "required": true },
          { "name": "name", "type": "string", "required": true },
          { "name": "description", "type": "string" },
          { "name": "status", "type": "enum", "values": ["planning", "active", "completed", "on-hold"], "default": "planning" },
          { "name": "progress", "type": "number", "default": 0 },
          { "name": "budget", "type": "number" },
          { "name": "startDate", "type": "date" },
          { "name": "endDate", "type": "date" },
          { "name": "teamSize", "type": "number" }
        ]
      },
      "traits": [
        {
          "name": "DashboardViewer",
          "category": "interaction",
          "linkedEntity": "Project",
          "stateMachine": {
            "states": [
              { "name": "overview", "isInitial": true },
              { "name": "detail" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "VIEW", "name": "View Project", "payload": [{ "name": "id", "type": "string", "required": true }] },
              { "key": "BACK", "name": "Go Back" }
            ],
            "transitions": [
              {
                "from": "overview",
                "event": "INIT",
                "to": "overview",
                "effects": [
                  ["fetch", "Project"],
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Templates - Dashboard",
                    "subtitle": "Dashboard layout with stats cards and data overview"
                  }],
                  ["render-ui", "sidebar", {
                    "type": "stats",
                    "metrics": [
                      { "label": "Total Projects", "value": "24", "icon": "folder" },
                      { "label": "Active", "value": "12", "icon": "activity" },
                      { "label": "Completed", "value": "10", "icon": "check-circle" },
                      { "label": "On Hold", "value": "2", "icon": "circle-pause" }
                    ]
                  }],
                  ["render-ui", "center", {
                    "type": "entity-table",
                    "entity": "Project",
                    "columns": ["name", "status", "progress", "budget"],
                    "itemActions": [
                      { "event": "VIEW", "label": "View" }
                    ]
                  }]
                ]
              },
              {
                "from": "overview",
                "event": "VIEW",
                "to": "detail",
                "effects": [
                  ["fetch", "Project", "@payload.id"],
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Project Details",
                    "showBack": true
                  }],
                  ["render-ui", "center", {
                    "type": "entity-detail",
                    "entity": "Project",
                    "fields": ["name", "description", "status", "progress", "budget", "startDate", "endDate", "teamSize"]
                  }]
                ]
              },
              {
                "from": "detail",
                "event": "BACK",
                "to": "overview",
                "effects": [
                  ["navigate", "/templates"]
                ]
              }
            ]
          }
        },
        {
          "name": "MasterDetailViewer",
          "category": "interaction",
          "linkedEntity": "Project",
          "stateMachine": {
            "states": [
              { "name": "browsing", "isInitial": true },
              { "name": "selected" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SELECT", "name": "Select Project", "payload": [{ "name": "id", "type": "string", "required": true }] },
              { "key": "DESELECT", "name": "Deselect" }
            ],
            "transitions": [
              {
                "from": "browsing",
                "event": "INIT",
                "to": "browsing",
                "effects": [
                  ["fetch", "Project"],
                  ["render-ui", "main", {
                    "type": "page-header",
                    "title": "Templates - Master Detail",
                    "subtitle": "Side-by-side list and detail panel layout"
                  }],
                  ["render-ui", "sidebar", {
                    "type": "entity-list",
                    "entity": "Project",
                    "fieldNames": ["name", "status"],
                    "itemActions": [
                      { "event": "SELECT", "label": "Select" }
                    ]
                  }]
                ]
              },
              {
                "from": "browsing",
                "event": "SELECT",
                "to": "selected",
                "effects": [
                  ["fetch", "Project", "@payload.id"],
                  ["render-ui", "drawer", {
                    "type": "detail-panel",
                    "entity": "Project",
                    "fields": ["name", "description", "status", "progress", "budget", "startDate", "endDate"],
                    "actions": [
                      { "label": "Close", "event": "DESELECT" }
                    ]
                  }]
                ]
              },
              {
                "from": "selected",
                "event": "SELECT",
                "to": "selected",
                "effects": [
                  ["fetch", "Project", "@payload.id"],
                  ["render-ui", "drawer", {
                    "type": "detail-panel",
                    "entity": "Project",
                    "fields": ["name", "description", "status", "progress", "budget", "startDate", "endDate"],
                    "actions": [
                      { "label": "Close", "event": "DESELECT" }
                    ]
                  }]
                ]
              },
              {
                "from": "selected",
                "event": "DESELECT",
                "to": "browsing"
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "DashboardPage",
          "path": "/templates",
          "traits": [
            { "ref": "DashboardViewer", "linkedEntity": "Project" }
          ]
        },
        {
          "name": "MasterDetailPage",
          "path": "/templates/master-detail",
          "traits": [
            { "ref": "MasterDetailViewer", "linkedEntity": "Project" }
          ]
        }
      ]
    },
