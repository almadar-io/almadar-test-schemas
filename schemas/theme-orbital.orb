          { "name": "priority", "type": "enum", "values": ["low", "medium", "high"], "default": "medium" },
          { "name": "isActive", "type": "boolean", "default": true }
        ]
      },
      "traits": [
        {
          "name": "SearchFilterDemo",
          "category": "interaction",
          "linkedEntity": "SearchableItem",
          "stateMachine": {
            "states": [
              { "name": "idle", "isInitial": true },
              { "name": "searching" },
              { "name": "filtered" }
            ],
            "events": [
              { "key": "INIT", "name": "Initialize" },
              { "key": "SEARCH", "name": "Search", "payload": [{ "name": "term", "type": "string" }] },
              { "key": "FILTER", "name": "Apply Filter", "payload": [{ "name": "field", "type": "string" }, { "name": "value", "type": "string" }] },
              { "key": "CLEAR", "name": "Clear Filters" }
            ],
            "transitions": [
              {
                "from": "idle",
                "event": "INIT",
