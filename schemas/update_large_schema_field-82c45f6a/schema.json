    {
      "name": "TaskWorkflow",
      "category": "integration",
      "stateMachine": {
        "states": [
          { "name": "backlog", "isInitial": true },
          { "name": "todo" },
          { "name": "in_progress" },
          { "name": "in_review" },
          { "name": "done" }
        ],
        "events": [
          { "key": "MOVE_TO_TODO", "name": "Move to Todo" },
          { "key": "START_WORK", "name": "Start Work" },
          { "key": "SUBMIT_FOR_REVIEW", "name": "Submit for Review" },
          { "key": "APPROVE", "name": "Approve" },
          { "key": "REQUEST_CHANGES", "name": "Request Changes" },
          { "key": "REOPEN", "name": "Reopen" }
        ],
        "transitions": [
          {
            "from": "backlog",
            "to": "todo",
            "event": "MOVE_TO_TODO",
            "effects": [["set", "@entity.status", "todo"], ["emit", "TASK_UPDATED", "@entity"]]
          },
          {
            "from": "todo",
            "to": "in_progress",
            "event": "START_WORK",
            "effects": [["set", "@entity.status", "in_progress"], ["emit", "TASK_UPDATED", "@entity"]]
          },
          {
            "from": "in_progress",
            "to": "in_review",
            "event": "SUBMIT_FOR_REVIEW",
            "effects": [["set", "@entity.status", "in_review"], ["emit", "TASK_UPDATED", "@entity"]]
          },
          {
            "from": "in_review",
            "to": "done",
            "event": "APPROVE",
            "effects": [["set", "@entity.status", "done"], ["emit", "TASK_COMPLETED", "@entity"]]
          },
          {
            "from": "in_review",
            "to": "in_progress",
            "event": "REQUEST_CHANGES",
            "effects": [["set", "@entity.status", "in_progress"], ["emit", "TASK_UPDATED", "@entity"]]
          },
          {
            "from": "done",
            "to": "todo",
            "event": "REOPEN",
            "effects": [["set", "@entity.status", "todo"], ["emit", "TASK_UPDATED", "@entity"]]
          }
        ]
      }
    },
