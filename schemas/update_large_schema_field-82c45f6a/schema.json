{
  "name": "ProjectManagementSuite",
  "version": "2.1.0",
  "description": "Enterprise project management application with tasks, sprints, teams, and reporting",
  "orbitals": [
    {
      "name": "ProjectOrbital",
      "entity": {
        "name": "Project",
        "persistence": { "collection": "projects" },
        "fields": [
          { "name": "name", "type": "string", "required": true },
          { "name": "description", "type": "string" },
          { "name": "status", "type": "enum", "values": ["planning", "active", "on_hold", "completed", "archived"], "default": "planning" },
          { "name": "startDate", "type": "date" },
          { "name": "endDate", "type": "date" },
          { "name": "budget", "type": "number", "default": 0 },
          { "name": "spentBudget", "type": "number", "default": 0 },
          { "name": "ownerId", "type": "string", "required": true },
          { "name": "teamIds", "type": "array" },
          { "name": "visibility", "type": "enum", "values": ["private", "team", "public"], "default": "team" },
          { "name": "tags", "type": "array" },
          { "name": "createdAt", "type": "timestamp" },
          { "name": "updatedAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "ProjectInteraction" }, { "ref": "ProjectLifecycle" }],
      "pages": [
        { "name": "ProjectsPage", "path": "/projects", "traits": [{ "ref": "ProjectInteraction" }] },
        { "name": "ProjectDetailPage", "path": "/projects/:id", "traits": [{ "ref": "ProjectInteraction" }] }
      ],
      "emits": ["PROJECT_CREATED", "PROJECT_UPDATED", "PROJECT_ARCHIVED", "PROJECT_COMPLETED"],
      "listens": [
        { "event": "SPRINT_COMPLETED", "dispatch": "CHECK_PROJECT_COMPLETION" }
      ]
    },
    {
      "name": "SprintOrbital",
      "entity": {
        "name": "Sprint",
        "persistence": { "collection": "sprints" },
        "fields": [
          { "name": "name", "type": "string", "required": true },
          { "name": "projectId", "type": "string", "required": true },
          { "name": "goal", "type": "string" },
          { "name": "status", "type": "enum", "values": ["planning", "active", "review", "completed"], "default": "planning" },
          { "name": "startDate", "type": "date", "required": true },
          { "name": "endDate", "type": "date", "required": true },
          { "name": "velocity", "type": "number", "default": 0 },
          { "name": "plannedPoints", "type": "number", "default": 0 },
          { "name": "completedPoints", "type": "number", "default": 0 },
          { "name": "createdAt", "type": "timestamp" },
          { "name": "updatedAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "SprintInteraction" }, { "ref": "SprintLifecycle" }],
      "pages": [
        { "name": "SprintsPage", "path": "/projects/:projectId/sprints", "traits": [{ "ref": "SprintInteraction" }] }
      ],
      "emits": ["SPRINT_STARTED", "SPRINT_COMPLETED", "SPRINT_VELOCITY_UPDATED"],
      "listens": [
        { "event": "TASK_COMPLETED", "dispatch": "UPDATE_SPRINT_PROGRESS" }
      ]
    },
    {
      "name": "TaskOrbital",
      "entity": {
        "name": "Task",
        "persistence": { "collection": "tasks" },
        "fields": [
          { "name": "title", "type": "string", "required": true },
          { "name": "description", "type": "string" },
          { "name": "status", "type": "enum", "values": ["backlog", "todo", "in_progress", "in_review", "done"], "default": "backlog" },
          { "name": "priority", "type": "enum", "values": ["low", "medium", "high", "critical"], "default": "medium" },
          { "name": "type", "type": "enum", "values": ["feature", "bug", "chore", "spike"], "default": "feature" },
          { "name": "storyPoints", "type": "number" },
          { "name": "projectId", "type": "string", "required": true },
          { "name": "sprintId", "type": "string" },
          { "name": "assigneeId", "type": "string" },
          { "name": "reporterId", "type": "string", "required": true },
          { "name": "labelIds", "type": "array" },
          { "name": "dueDate", "type": "date" },
          { "name": "estimatedHours", "type": "number" },
          { "name": "loggedHours", "type": "number", "default": 0 },
          { "name": "blockedBy", "type": "array" },
          { "name": "blocks", "type": "array" },
          { "name": "attachments", "type": "array" },
          { "name": "subtasks", "type": "array" },
          { "name": "createdAt", "type": "timestamp" },
          { "name": "updatedAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "TaskInteraction" }, { "ref": "TaskWorkflow" }],
      "pages": [
        { "name": "TaskBoardPage", "path": "/projects/:projectId/board", "traits": [{ "ref": "TaskInteraction" }] },
        { "name": "TaskListPage", "path": "/projects/:projectId/tasks", "traits": [{ "ref": "TaskInteraction" }] },
        { "name": "TaskDetailPage", "path": "/tasks/:id", "traits": [{ "ref": "TaskInteraction" }] }
      ],
      "emits": ["TASK_CREATED", "TASK_UPDATED", "TASK_ASSIGNED", "TASK_COMPLETED", "TASK_BLOCKED"],
      "listens": []
    },
    {
      "name": "UserOrbital",
      "entity": {
        "name": "User",
        "persistence": { "collection": "users" },
        "fields": [
          { "name": "email", "type": "string", "required": true },
          { "name": "displayName", "type": "string", "required": true },
          { "name": "avatarUrl", "type": "string" },
          { "name": "role", "type": "enum", "values": ["admin", "manager", "developer", "viewer"], "default": "developer" },
          { "name": "teamIds", "type": "array" },
          { "name": "skills", "type": "array" },
          { "name": "capacity", "type": "number", "default": 40 },
          { "name": "timezone", "type": "string", "default": "UTC" },
          { "name": "notificationPrefs", "type": "object" },
          { "name": "lastActiveAt", "type": "timestamp" },
          { "name": "createdAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "UserInteraction" }, { "ref": "UserProfile" }],
      "pages": [
        { "name": "TeamPage", "path": "/team", "traits": [{ "ref": "UserInteraction" }] },
        { "name": "ProfilePage", "path": "/profile/:id", "traits": [{ "ref": "UserProfile" }] }
      ],
      "emits": ["USER_UPDATED", "USER_ROLE_CHANGED"],
      "listens": []
    },
    {
      "name": "CommentOrbital",
      "entity": {
        "name": "Comment",
        "persistence": { "collection": "comments" },
        "fields": [
          { "name": "content", "type": "string", "required": true },
          { "name": "taskId", "type": "string", "required": true },
          { "name": "authorId", "type": "string", "required": true },
          { "name": "parentId", "type": "string" },
          { "name": "mentions", "type": "array" },
          { "name": "attachments", "type": "array" },
          { "name": "reactions", "type": "object" },
          { "name": "editedAt", "type": "timestamp" },
          { "name": "createdAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "CommentInteraction" }],
      "pages": [],
      "emits": ["COMMENT_ADDED", "COMMENT_EDITED", "USER_MENTIONED"],
      "listens": []
    },
    {
      "name": "LabelOrbital",
      "entity": {
        "name": "Label",
        "persistence": { "collection": "labels" },
        "fields": [
          { "name": "name", "type": "string", "required": true },
          { "name": "color", "type": "string", "required": true },
          { "name": "projectId", "type": "string", "required": true },
          { "name": "description", "type": "string" },
          { "name": "createdAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "LabelInteraction" }],
      "pages": [
        { "name": "LabelsPage", "path": "/projects/:projectId/labels", "traits": [{ "ref": "LabelInteraction" }] }
      ],
      "emits": ["LABEL_CREATED", "LABEL_UPDATED", "LABEL_DELETED"],
      "listens": []
    },
    {
      "name": "TimeEntryOrbital",
      "entity": {
        "name": "TimeEntry",
        "persistence": { "collection": "time_entries" },
        "fields": [
          { "name": "taskId", "type": "string", "required": true },
          { "name": "userId", "type": "string", "required": true },
          { "name": "hours", "type": "number", "required": true },
          { "name": "description", "type": "string" },
          { "name": "date", "type": "date", "required": true },
          { "name": "billable", "type": "boolean", "default": true },
          { "name": "createdAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "TimeEntryInteraction" }],
      "pages": [
        { "name": "TimeTrackingPage", "path": "/timesheet", "traits": [{ "ref": "TimeEntryInteraction" }] }
      ],
      "emits": ["TIME_LOGGED", "TIME_UPDATED"],
      "listens": []
    },
    {
      "name": "NotificationOrbital",
      "entity": {
        "name": "Notification",
        "persistence": { "collection": "notifications" },
        "fields": [
          { "name": "userId", "type": "string", "required": true },
          { "name": "type", "type": "enum", "values": ["mention", "assignment", "comment", "status_change", "due_date", "sprint_start", "sprint_end"], "required": true },
          { "name": "title", "type": "string", "required": true },
          { "name": "message", "type": "string" },
          { "name": "entityType", "type": "string" },
          { "name": "entityId", "type": "string" },
          { "name": "read", "type": "boolean", "default": false },
          { "name": "actionUrl", "type": "string" },
          { "name": "createdAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "NotificationInteraction" }],
      "pages": [],
      "emits": [],
      "listens": [
        { "event": "USER_MENTIONED", "dispatch": "CREATE_MENTION_NOTIFICATION" },
        { "event": "TASK_ASSIGNED", "dispatch": "CREATE_ASSIGNMENT_NOTIFICATION" },
        { "event": "COMMENT_ADDED", "dispatch": "CREATE_COMMENT_NOTIFICATION" }
      ]
    },
    {
      "name": "ReportOrbital",
      "entity": {
        "name": "Report",
        "persistence": { "runtime": true },
        "fields": [
          { "name": "type", "type": "enum", "values": ["velocity", "burndown", "burnup", "cumulative_flow", "cycle_time"], "required": true },
          { "name": "projectId", "type": "string" },
          { "name": "sprintId", "type": "string" },
          { "name": "dateRange", "type": "object" },
          { "name": "data", "type": "object" },
          { "name": "generatedAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "ReportInteraction" }],
      "pages": [
        { "name": "ReportsPage", "path": "/reports", "traits": [{ "ref": "ReportInteraction" }] },
        { "name": "VelocityReportPage", "path": "/reports/velocity", "traits": [{ "ref": "ReportInteraction" }] },
        { "name": "BurndownPage", "path": "/reports/burndown", "traits": [{ "ref": "ReportInteraction" }] }
      ],
      "emits": [],
      "listens": []
    },
    {
      "name": "IntegrationOrbital",
      "entity": {
        "name": "Integration",
        "persistence": { "collection": "integrations" },
        "fields": [
          { "name": "projectId", "type": "string", "required": true },
          { "name": "type", "type": "enum", "values": ["github", "gitlab", "slack", "jira", "confluence", "figma"], "required": true },
          { "name": "status", "type": "enum", "values": ["active", "inactive", "error"], "default": "inactive" },
          { "name": "config", "type": "object" },
          { "name": "credentials", "type": "object" },
          { "name": "lastSyncAt", "type": "timestamp" },
          { "name": "errorMessage", "type": "string" },
          { "name": "createdAt", "type": "timestamp" }
        ]
      },
      "traits": [{ "ref": "IntegrationInteraction" }],
      "pages": [
        { "name": "IntegrationsPage", "path": "/projects/:projectId/integrations", "traits": [{ "ref": "IntegrationInteraction" }] }
      ],
      "emits": ["INTEGRATION_SYNCED", "INTEGRATION_ERROR"],
      "listens": []
    }
  ],
  "traits": [
    {
      "name": "ProjectInteraction",
      "category": "interaction",
      "stateMachine": {
        "states": [
          { "name": "browsing", "isInitial": true },
          { "name": "creating" },
          { "name": "viewing" },
          { "name": "editing" },
          { "name": "archiving" }
        ],
        "events": [
          { "key": "INIT", "name": "Initialize" },
          { "key": "CREATE", "name": "Create Project" },
          { "key": "VIEW", "name": "View Project" },
          { "key": "EDIT", "name": "Edit Project" },
          { "key": "ARCHIVE", "name": "Archive Project" },
          { "key": "SAVE", "name": "Save" },
          { "key": "CANCEL", "name": "Cancel" },
          { "key": "CONFIRM", "name": "Confirm" }
        ],
        "transitions": [
          {
            "from": "browsing",
            "to": "browsing",
            "event": "INIT",
            "effects": [
              ["render-ui", "main", {
                "type": "page-header",
                "title": "Projects",
                "actions": [
                  { "label": "New Project", "event": "CREATE", "variant": "primary" }
                ]
              }],
              ["render-ui", "main", {
                "type": "entity-cards",
                "entity": "Project",
                "fieldNames": ["name", "status", "startDate", "endDate"],
                "itemActions": [
                  { "label": "View", "event": "VIEW" },
                  { "label": "Edit", "event": "EDIT" },
                  { "label": "Archive", "event": "ARCHIVE", "variant": "destructive" }
                ]
              }]
            ]
          },
          {
            "from": "browsing",
            "to": "creating",
            "event": "CREATE",
            "effects": [
              ["render-ui", "modal", {
                "type": "form-section",
                "entity": "Project",
                "title": "Create Project",
                "fields": ["name", "description", "startDate", "endDate", "budget", "visibility"],
                "onSubmit": "SAVE",
                "onCancel": "CANCEL"
              }]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              ["emit", "PROJECT_CREATED", "@payload"],
              ["render-ui", "modal", null]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [["render-ui", "modal", null]]
          },
          {
            "from": "browsing",
            "to": "viewing",
            "event": "VIEW",
            "effects": [
              ["render-ui", "drawer", {
                "type": "entity-detail",
                "entity": "Project",
                "fieldNames": ["name", "description", "status", "startDate", "endDate", "budget", "spentBudget"],
                "headerActions": [
                  { "label": "Edit", "event": "EDIT" },
                  { "label": "Close", "event": "CANCEL" }
                ]
              }]
            ]
          },
          {
            "from": "viewing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [["render-ui", "drawer", null]]
          },
          {
            "from": ["browsing", "viewing"],
            "to": "editing",
            "event": "EDIT",
            "effects": [
              ["render-ui", "modal", {
                "type": "form-section",
                "entity": "Project",
                "title": "Edit Project",
                "fields": ["name", "description", "status", "startDate", "endDate", "budget", "visibility"],
                "onSubmit": "SAVE",
                "onCancel": "CANCEL"
              }]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              ["emit", "PROJECT_UPDATED", "@payload"],
              ["render-ui", "modal", null],
              ["render-ui", "drawer", null]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [["render-ui", "modal", null]]
          },
          {
            "from": "browsing",
            "to": "archiving",
            "event": "ARCHIVE",
            "effects": [
              ["render-ui", "modal", {
                "type": "confirmation",
                "title": "Archive Project",
                "message": "Are you sure you want to archive this project? All associated sprints and tasks will be archived.",
                "onConfirm": "CONFIRM",
                "onCancel": "CANCEL"
              }]
            ]
          },
          {
            "from": "archiving",
            "to": "browsing",
            "event": "CONFIRM",
            "effects": [
              ["set", "@entity.status", "archived"],
              ["emit", "PROJECT_ARCHIVED", "@entity"],
              ["render-ui", "modal", null]
            ]
          },
          {
            "from": "archiving",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [["render-ui", "modal", null]]
          }
        ]
      }
    },
    {
      "name": "ProjectLifecycle",
      "category": "integration",
      "stateMachine": {
        "states": [
          { "name": "planning", "isInitial": true },
          { "name": "active" },
          { "name": "on_hold" },
          { "name": "completed" },
          { "name": "archived" }
        ],
        "events": [
          { "key": "START", "name": "Start Project" },
          { "key": "PAUSE", "name": "Pause Project" },
          { "key": "RESUME", "name": "Resume Project" },
          { "key": "COMPLETE", "name": "Complete Project" },
          { "key": "ARCHIVE", "name": "Archive Project" },
          { "key": "CHECK_PROJECT_COMPLETION", "name": "Check Completion" }
        ],
        "transitions": [
          {
            "from": "planning",
            "to": "active",
            "event": "START",
            "effects": [
              ["set", "@entity.status", "active"],
              ["emit", "PROJECT_UPDATED", "@entity"]
            ]
          },
          {
            "from": "active",
            "to": "on_hold",
            "event": "PAUSE",
            "effects": [
              ["set", "@entity.status", "on_hold"],
              ["emit", "PROJECT_UPDATED", "@entity"]
            ]
          },
          {
            "from": "on_hold",
            "to": "active",
            "event": "RESUME",
            "effects": [
              ["set", "@entity.status", "active"],
              ["emit", "PROJECT_UPDATED", "@entity"]
            ]
          },
          {
            "from": "active",
            "to": "completed",
            "event": "COMPLETE",
            "effects": [
              ["set", "@entity.status", "completed"],
              ["emit", "PROJECT_COMPLETED", "@entity"]
            ]
          },
          {
            "from": ["planning", "active", "on_hold", "completed"],
            "to": "archived",
            "event": "ARCHIVE",
            "effects": [
              ["set", "@entity.status", "archived"],
              ["emit", "PROJECT_ARCHIVED", "@entity"]
            ]
          }
        ]
      }
    },
    {
      "name": "SprintInteraction",
      "category": "interaction",
      "stateMachine": {
        "states": [
          { "name": "browsing", "isInitial": true },
          { "name": "creating" },
          { "name": "viewing" },
          { "name": "editing" }
        ],
        "events": [
          { "key": "INIT", "name": "Initialize" },
          { "key": "CREATE", "name": "Create Sprint" },
          { "key": "VIEW", "name": "View Sprint" },
          { "key": "EDIT", "name": "Edit Sprint" },
          { "key": "SAVE", "name": "Save" },
          { "key": "CANCEL", "name": "Cancel" }
        ],
        "transitions": [
          {
            "from": "browsing",
            "to": "browsing",
            "event": "INIT",
            "effects": [
              ["render-ui", "main", {
                "type": "page-header",
                "title": "Sprints",
                "actions": [{ "label": "New Sprint", "event": "CREATE", "variant": "primary" }]
              }],
              ["render-ui", "main", {
                "type": "entity-table",
                "entity": "Sprint",
                "columns": ["name", "status", "startDate", "endDate", "velocity"],
                "itemActions": [
                  { "label": "View", "event": "VIEW" },
                  { "label": "Edit", "event": "EDIT" }
                ]
              }]
            ]
          },
          {
            "from": "browsing",
            "to": "creating",
            "event": "CREATE",
            "effects": [
              ["render-ui", "modal", {
                "type": "form-section",
                "entity": "Sprint",
                "title": "Create Sprint",
                "fields": ["name", "goal", "startDate", "endDate", "plannedPoints"],
                "onSubmit": "SAVE",
                "onCancel": "CANCEL"
              }]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "SAVE",
            "effects": [["emit", "SPRINT_CREATED", "@payload"], ["render-ui", "modal", null]]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [["render-ui", "modal", null]]
          },
          {
            "from": "browsing",
            "to": "viewing",
            "event": "VIEW",
            "effects": [
              ["render-ui", "drawer", {
                "type": "entity-detail",
                "entity": "Sprint",
                "fieldNames": ["name", "goal", "status", "startDate", "endDate", "plannedPoints", "completedPoints", "velocity"],
                "headerActions": [{ "label": "Edit", "event": "EDIT" }, { "label": "Close", "event": "CANCEL" }]
              }]
            ]
          },
          {
            "from": "viewing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [["render-ui", "drawer", null]]
          },
          {
            "from": ["browsing", "viewing"],
            "to": "editing",
            "event": "EDIT",
            "effects": [
              ["render-ui", "modal", {
                "type": "form-section",
                "entity": "Sprint",
                "title": "Edit Sprint",
                "fields": ["name", "goal", "status", "startDate", "endDate", "plannedPoints"],
                "onSubmit": "SAVE",
                "onCancel": "CANCEL"
              }]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "SAVE",
            "effects": [["emit", "SPRINT_UPDATED", "@payload"], ["render-ui", "modal", null], ["render-ui", "drawer", null]]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [["render-ui", "modal", null]]
          }
        ]
      }
    },
    {
      "name": "SprintLifecycle",
      "category": "integration",
      "stateMachine": {
        "states": [
          { "name": "planning", "isInitial": true },
          { "name": "active" },
          { "name": "review" },
          { "name": "completed" }
        ],
        "events": [
          { "key": "START_SPRINT", "name": "Start Sprint" },
          { "key": "END_SPRINT", "name": "End Sprint" },
          { "key": "COMPLETE_REVIEW", "name": "Complete Review" },
          { "key": "UPDATE_SPRINT_PROGRESS", "name": "Update Progress" }
        ],
        "transitions": [
          {
            "from": "planning",
            "to": "active",
            "event": "START_SPRINT",
            "effects": [
              ["set", "@entity.status", "active"],
              ["emit", "SPRINT_STARTED", "@entity"]
            ]
          },
          {
            "from": "active",
            "to": "review",
            "event": "END_SPRINT",
            "effects": [["set", "@entity.status", "review"]]
          },
          {
            "from": "review",
            "to": "completed",
            "event": "COMPLETE_REVIEW",
            "effects": [
              ["set", "@entity.status", "completed"],
              ["emit", "SPRINT_COMPLETED", "@entity"]
            ]
