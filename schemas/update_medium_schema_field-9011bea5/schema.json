{
  "name": "ProjectManagementSuite",
  "version": "2.1.0",
  "description": "Enterprise project management application with tasks, sprints, teams, and reporting",
  "orbitals": [
    {
      "name": "ProjectOrbital",
      "entity": {
        "name": "Project",
        "persistence": {
          "collection": "projects"
        },
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "enum",
            "values": [
              "planning",
              "active",
              "on_hold",
              "completed",
              "archived"
            ],
            "default": "planning"
          },
          {
            "name": "startDate",
            "type": "date"
          },
          {
            "name": "endDate",
            "type": "date"
          },
          {
            "name": "budget",
            "type": "number",
            "default": 0
          },
          {
            "name": "spentBudget",
            "type": "number",
            "default": 0
          },
          {
            "name": "ownerId",
            "type": "string",
            "required": true
          },
          {
            "name": "teamIds",
            "type": "array"
          },
          {
            "name": "visibility",
            "type": "enum",
            "values": [
              "private",
              "team",
              "public"
            ],
            "default": "team"
          },
          {
            "name": "tags",
            "type": "array"
          },
          {
            "name": "createdAt",
            "type": "timestamp"
          },
          {
            "name": "updatedAt",
            "type": "timestamp"
          }
        ]
      },
      "traits": [
        {
          "ref": "ProjectInteraction"
        },
        {
          "ref": "ProjectLifecycle"
        }
      ],
      "pages": [
        {
          "name": "ProjectsPage",
          "path": "/projects",
          "traits": [
            {
              "ref": "ProjectInteraction"
            }
          ]
        },
        {
          "name": "ProjectDetailPage",
          "path": "/projects/:id",
          "traits": [
            {
              "ref": "ProjectInteraction"
            }
          ]
        }
      ],
      "emits": [
        "PROJECT_CREATED",
        "PROJECT_UPDATED",
        "PROJECT_ARCHIVED",
        "PROJECT_COMPLETED"
      ],
      "listens": [
        {
          "event": "SPRINT_COMPLETED",
          "dispatch": "CHECK_PROJECT_COMPLETION"
        }
      ]
    },
    {
      "name": "SprintOrbital",
      "entity": {
        "name": "Sprint",
        "persistence": {
          "collection": "sprints"
        },
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "projectId",
            "type": "string",
            "required": true
          },
          {
            "name": "goal",
            "type": "string"
          },
          {
            "name": "status",
            "type": "enum",
            "values": [
              "planning",
              "active",
              "review",
              "completed"
            ],
            "default": "planning"
          },
          {
            "name": "startDate",
            "type": "date",
            "required": true
          },
          {
            "name": "endDate",
            "type": "date",
            "required": true
          },
          {
            "name": "velocity",
            "type": "number",
            "default": 0
          },
          {
            "name": "plannedPoints",
            "type": "number",
            "default": 0
          },
          {
            "name": "completedPoints",
            "type": "number",
            "default": 0
          },
          {
            "name": "createdAt",
            "type": "timestamp"
          },
          {
            "name": "updatedAt",
            "type": "timestamp"
          }
        ]
      },
      "traits": [
        {
          "ref": "SprintInteraction"
        },
        {
          "ref": "SprintLifecycle"
        }
      ],
      "pages": [
        {
          "name": "SprintsPage",
          "path": "/projects/:projectId/sprints",
          "traits": [
            {
              "ref": "SprintInteraction"
            }
          ]
        }
      ],
      "emits": [
        "SPRINT_STARTED",
        "SPRINT_COMPLETED",
        "SPRINT_VELOCITY_UPDATED"
      ],
      "listens": [
        {
          "event": "TASK_COMPLETED",
          "dispatch": "UPDATE_SPRINT_PROGRESS"
        }
      ]
    },
    {
      "name": "TaskOrbital",
      "entity": {
        "name": "Task",
        "persistence": {
          "collection": "tasks"
        },
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "status",
            "type": "enum",
            "values": [
              "backlog",
              "todo",
              "in_progress",
              "in_review",
              "done"
            ],
            "default": "backlog"
          },
          {
            "name": "priority",
            "type": "enum",
            "values": [
              "low",
              "medium",
              "high",
              "critical"
            ],
            "default": "medium"
          },
          {
            "name": "type",
            "type": "enum",
            "values": [
              "feature",
              "bug",
              "chore",
              "spike"
            ],
            "default": "feature"
          },
          {
            "name": "storyPoints",
            "type": "number"
          },
          {
            "name": "projectId",
            "type": "string",
            "required": true
          },
          {
            "name": "sprintId",
            "type": "string"
          },
          {
            "name": "assigneeId",
            "type": "string"
          },
          {
            "name": "reporterId",
            "type": "string",
            "required": true
          },
          {
            "name": "labelIds",
            "type": "array"
          },
          {
            "name": "dueDate",
            "type": "date"
          },
          {
            "name": "estimatedHours",
            "type": "number"
          },
          {
            "name": "loggedHours",
            "type": "number",
            "default": 0
          },
          {
            "name": "blockedBy",
            "type": "array"
          },
          {
            "name": "blocks",
            "type": "array"
          },
          {
            "name": "attachments",
            "type": "array"
          },
          {
            "name": "createdAt",
            "type": "timestamp"
          },
          {
            "name": "updatedAt",
            "type": "timestamp"
          }
        ]
      },
      "traits": [
        {
          "ref": "TaskInteraction"
        },
        {
          "ref": "TaskWorkflow"
        }
      ],
      "pages": [
        {
          "name": "TaskBoardPage",
          "path": "/projects/:projectId/board",
          "traits": [
            {
              "ref": "TaskInteraction"
            }
          ]
        },
        {
          "name": "TaskListPage",
          "path": "/projects/:projectId/tasks",
          "traits": [
            {
              "ref": "TaskInteraction"
            }
          ]
        },
        {
          "name": "TaskDetailPage",
          "path": "/tasks/:id",
          "traits": [
            {
              "ref": "TaskInteraction"
            }
          ]
        }
      ],
      "emits": [
        "TASK_CREATED",
        "TASK_UPDATED",
        "TASK_ASSIGNED",
        "TASK_COMPLETED",
        "TASK_BLOCKED"
      ],
      "listens": []
    }
  ],
  "traits": [
    {
      "name": "ProjectInteraction",
      "category": "interaction",
      "stateMachine": {
        "states": [
          {
            "name": "browsing",
            "isInitial": true
          },
          {
            "name": "creating"
          },
          {
            "name": "viewing"
          },
          {
            "name": "editing"
          },
          {
            "name": "archiving"
          }
        ],
        "events": [
          {
            "key": "INIT",
            "name": "Initialize"
          },
          {
            "key": "CREATE",
            "name": "Create Project"
          },
          {
            "key": "VIEW",
            "name": "View Project"
          },
          {
            "key": "EDIT",
            "name": "Edit Project"
          },
          {
            "key": "ARCHIVE",
            "name": "Archive Project"
          },
          {
            "key": "SAVE",
            "name": "Save"
          },
          {
            "key": "CANCEL",
            "name": "Cancel"
          },
          {
            "key": "CONFIRM",
            "name": "Confirm"
          }
        ],
        "transitions": [
          {
            "from": "browsing",
            "to": "browsing",
            "event": "INIT",
            "effects": [
              [
                "render-ui",
                "main",
                {
                  "type": "page-header",
                  "title": "Projects",
                  "actions": [
                    {
                      "label": "New Project",
                      "event": "CREATE",
                      "variant": "primary"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "entity-cards",
                  "entity": "Project",
                  "fieldNames": [
                    "name",
                    "status",
                    "startDate",
                    "endDate"
                  ],
                  "itemActions": [
                    {
                      "label": "View",
                      "event": "VIEW"
                    },
                    {
                      "label": "Edit",
                      "event": "EDIT"
                    },
                    {
                      "label": "Archive",
                      "event": "ARCHIVE",
                      "variant": "destructive"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "creating",
            "event": "CREATE",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "entity": "Project",
                  "title": "Create Project",
                  "fields": [
                    "name",
                    "description",
                    "startDate",
                    "endDate",
                    "budget",
                    "visibility"
                  ],
                  "onSubmit": "SAVE",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "emit",
                "PROJECT_CREATED",
                "@payload"
              ],
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "viewing",
            "event": "VIEW",
            "effects": [
              [
                "render-ui",
                "drawer",
                {
                  "type": "entity-detail",
                  "entity": "Project",
                  "fieldNames": [
                    "name",
                    "description",
                    "status",
                    "startDate",
                    "endDate",
                    "budget",
                    "spentBudget"
                  ],
                  "headerActions": [
                    {
                      "label": "Edit",
                      "event": "EDIT"
                    },
                    {
                      "label": "Close",
                      "event": "CANCEL"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ]
            ]
          },
          {
            "from": [
              "browsing",
              "viewing"
            ],
            "to": "editing",
            "event": "EDIT",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "entity": "Project",
                  "title": "Edit Project",
                  "fields": [
                    "name",
                    "description",
                    "status",
                    "startDate",
                    "endDate",
                    "budget",
                    "visibility"
                  ],
                  "onSubmit": "SAVE",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "emit",
                "PROJECT_UPDATED",
                "@payload"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "drawer",
                null
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "archiving",
            "event": "ARCHIVE",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "confirmation",
                  "title": "Archive Project",
                  "message": "Are you sure you want to archive this project? All associated sprints and tasks will be archived.",
                  "onConfirm": "CONFIRM",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "archiving",
            "to": "browsing",
            "event": "CONFIRM",
            "effects": [
              [
                "set",
                "@entity.status",
                "archived"
              ],
              [
                "emit",
                "PROJECT_ARCHIVED",
                "@entity"
              ],
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "archiving",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          }
        ]
      }
    },
    {
      "name": "ProjectLifecycle",
      "category": "integration",
      "stateMachine": {
        "states": [
          {
            "name": "planning",
            "isInitial": true
          },
          {
            "name": "active"
          },
          {
            "name": "on_hold"
          },
          {
            "name": "completed"
          },
          {
            "name": "archived"
          }
        ],
        "events": [
          {
            "key": "START",
            "name": "Start Project"
          },
          {
            "key": "PAUSE",
            "name": "Pause Project"
          },
          {
            "key": "RESUME",
            "name": "Resume Project"
          },
          {
            "key": "COMPLETE",
            "name": "Complete Project"
          },
          {
            "key": "ARCHIVE",
            "name": "Archive Project"
          },
          {
            "key": "CHECK_PROJECT_COMPLETION",
            "name": "Check Completion"
          }
        ],
        "transitions": [
          {
            "from": "planning",
            "to": "active",
            "event": "START",
            "effects": [
              [
                "set",
                "@entity.status",
                "active"
              ],
              [
                "emit",
                "PROJECT_UPDATED",
                "@entity"
              ]
            ]
          },
          {
            "from": "active",
            "to": "on_hold",
            "event": "PAUSE",
            "effects": [
              [
                "set",
                "@entity.status",
                "on_hold"
              ],
              [
                "emit",
                "PROJECT_UPDATED",
                "@entity"
              ]
            ]
          },
          {
            "from": "on_hold",
            "to": "active",
            "event": "RESUME",
            "effects": [
              [
                "set",
                "@entity.status",
                "active"
              ],
              [
                "emit",
                "PROJECT_UPDATED",
                "@entity"
              ]
            ]
          },
          {
            "from": "active",
            "to": "completed",
            "event": "COMPLETE",
            "effects": [
              [
                "set",
                "@entity.status",
                "completed"
              ],
              [
                "emit",
                "PROJECT_COMPLETED",
                "@entity"
              ]
            ]
          },
          {
            "from": [
              "planning",
              "active",
              "on_hold",
              "completed"
            ],
            "to": "archived",
            "event": "ARCHIVE",
            "effects": [
              [
                "set",
                "@entity.status",
                "archived"
              ],
              [
                "emit",
                "PROJECT_ARCHIVED",
                "@entity"
              ]
            ]
          }
        ]
      }
    },
