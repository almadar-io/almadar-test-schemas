    {
      "name": "SprintLifecycle",
      "category": "integration",
      "stateMachine": {
        "states": [
          {
            "name": "planning",
            "isInitial": true
          },
          {
            "name": "active"
          },
          {
            "name": "review"
          },
          {
            "name": "completed"
          }
        ],
        "events": [
          {
            "key": "START_SPRINT",
            "name": "Start Sprint"
          },
          {
            "key": "END_SPRINT",
            "name": "End Sprint"
          },
          {
            "key": "COMPLETE_REVIEW",
            "name": "Complete Review"
          },
          {
            "key": "UPDATE_SPRINT_PROGRESS",
            "name": "Update Progress"
          }
        ],
        "transitions": [
          {
            "from": "planning",
            "to": "active",
            "event": "START_SPRINT",
            "effects": [
              [
                "set",
                "@entity.status",
                "active"
              ],
              [
                "emit",
                "SPRINT_STARTED",
                "@entity"
              ]
            ]
          },
          {
            "from": "active",
            "to": "review",
            "event": "END_SPRINT",
            "effects": [
              [
                "set",
                "@entity.status",
                "review"
              ]
            ]
          },
          {
            "from": "review",
            "to": "completed",
            "event": "COMPLETE_REVIEW",
            "effects": [
              [
                "set",
                "@entity.status",
                "completed"
              ],
              [
                "emit",
                "SPRINT_COMPLETED",
                "@entity"
              ]
            ]
          },
          {
            "from": "active",
            "to": "active",
            "event": "UPDATE_SPRINT_PROGRESS",
            "effects": [
              [
                "increment",
                "@entity.completedPoints",
                "@payload.points"
              ],
              [
                "emit",
                "SPRINT_VELOCITY_UPDATED",
                "@entity"
              ]
            ]
          }
        ]
      }
    },
    {
      "name": "TaskInteraction",
      "category": "interaction",
      "stateMachine": {
        "states": [
          {
            "name": "browsing",
            "isInitial": true
          },
          {
            "name": "creating"
          },
          {
            "name": "viewing"
          },
          {
            "name": "editing"
          },
          {
            "name": "assigning"
          },
          {
            "name": "deleting"
          }
        ],
        "events": [
          {
            "key": "INIT",
            "name": "Initialize"
          },
          {
            "key": "CREATE",
            "name": "Create Task"
          },
          {
            "key": "VIEW",
            "name": "View Task"
          },
          {
            "key": "EDIT",
            "name": "Edit Task"
          },
          {
            "key": "ASSIGN",
            "name": "Assign Task"
          },
          {
            "key": "DELETE",
            "name": "Delete Task"
          },
          {
            "key": "SAVE",
            "name": "Save"
          },
          {
            "key": "CANCEL",
            "name": "Cancel"
          },
          {
            "key": "CONFIRM",
            "name": "Confirm"
          }
        ],
        "transitions": [
          {
            "from": "browsing",
            "to": "browsing",
            "event": "INIT",
            "effects": [
              [
                "render-ui",
                "main",
                {
                  "type": "page-header",
                  "title": "Tasks",
                  "actions": [
                    {
                      "label": "New Task",
                      "event": "CREATE",
                      "variant": "primary"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "entity-table",
                  "entity": "Task",
                  "columns": [
                    "title",
                    "status",
                    "priority",
                    "type",
                    "assigneeId",
                    "dueDate"
                  ],
                  "itemActions": [
                    {
                      "label": "View",
                      "event": "VIEW"
                    },
                    {
                      "label": "Edit",
                      "event": "EDIT"
                    },
                    {
                      "label": "Assign",
                      "event": "ASSIGN"
                    },
                    {
                      "label": "Delete",
                      "event": "DELETE",
                      "variant": "destructive"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "creating",
            "event": "CREATE",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "entity": "Task",
                  "title": "Create Task",
                  "fields": [
                    "title",
                    "description",
                    "type",
                    "priority",
                    "storyPoints",
                    "dueDate",
                    "estimatedHours"
                  ],
                  "onSubmit": "SAVE",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "emit",
                "TASK_CREATED",
                "@payload"
              ],
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "viewing",
            "event": "VIEW",
            "effects": [
              [
                "render-ui",
                "drawer",
                {
                  "type": "entity-detail",
                  "entity": "Task",
                  "fieldNames": [
                    "title",
                    "description",
                    "status",
                    "priority",
                    "type",
                    "storyPoints",
                    "assigneeId",
                    "dueDate",
                    "estimatedHours",
                    "loggedHours"
                  ],
                  "headerActions": [
                    {
                      "label": "Edit",
                      "event": "EDIT"
                    },
                    {
                      "label": "Assign",
                      "event": "ASSIGN"
                    },
                    {
                      "label": "Close",
                      "event": "CANCEL"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ]
            ]
          },
          {
            "from": [
              "browsing",
              "viewing"
            ],
            "to": "editing",
            "event": "EDIT",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "entity": "Task",
                  "title": "Edit Task",
                  "fields": [
                    "title",
                    "description",
                    "status",
                    "type",
                    "priority",
                    "storyPoints",
                    "dueDate",
                    "estimatedHours"
                  ],
                  "onSubmit": "SAVE",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "emit",
                "TASK_UPDATED",
                "@payload"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "drawer",
                null
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": [
              "browsing",
              "viewing"
            ],
            "to": "assigning",
            "event": "ASSIGN",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "entity": "Task",
                  "title": "Assign Task",
                  "fields": [
                    "assigneeId"
                  ],
                  "onSubmit": "SAVE",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "assigning",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "emit",
                "TASK_ASSIGNED",
                "@payload"
              ],
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "render-ui",
                "drawer",
                null
              ]
            ]
          },
          {
            "from": "assigning",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "deleting",
            "event": "DELETE",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "confirmation",
                  "title": "Delete Task",
                  "message": "Are you sure you want to delete this task? This action cannot be undone.",
                  "onConfirm": "CONFIRM",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "deleting",
            "to": "browsing",
            "event": "CONFIRM",
            "effects": [
              [
                "emit",
                "TASK_DELETED",
                "@entity"
              ],
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "deleting",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          }
        ]
      }
    },
    {
      "name": "TaskWorkflow",
      "category": "integration",
      "stateMachine": {
        "states": [
          {
            "name": "backlog",
            "isInitial": true
          },
          {
            "name": "todo"
          },
          {
            "name": "in_progress"
          },
          {
            "name": "in_review"
          },
          {
            "name": "done"
          }
        ],
        "events": [
          {
            "key": "MOVE_TO_TODO",
            "name": "Move to Todo"
          },
          {
            "key": "START_WORK",
            "name": "Start Work"
          },
          {
            "key": "SUBMIT_FOR_REVIEW",
            "name": "Submit for Review"
          },
          {
            "key": "APPROVE",
            "name": "Approve"
          },
          {
            "key": "REQUEST_CHANGES",
            "name": "Request Changes"
          },
          {
            "key": "REOPEN",
            "name": "Reopen"
          }
        ],
        "transitions": [
          {
            "from": "backlog",
            "to": "todo",
            "event": "MOVE_TO_TODO",
            "effects": [
              [
                "set",
                "@entity.status",
                "todo"
              ],
              [
                "emit",
                "TASK_UPDATED",
                "@entity"
              ]
            ]
          },
          {
            "from": "todo",
            "to": "in_progress",
            "event": "START_WORK",
            "effects": [
              [
                "set",
                "@entity.status",
                "in_progress"
              ],
              [
                "emit",
                "TASK_UPDATED",
                "@entity"
              ]
            ]
          },
          {
            "from": "in_progress",
            "to": "in_review",
            "event": "SUBMIT_FOR_REVIEW",
            "effects": [
              [
                "set",
                "@entity.status",
                "in_review"
              ],
              [
                "emit",
                "TASK_UPDATED",
                "@entity"
              ]
            ]
          },
          {
            "from": "in_review",
            "to": "done",
            "event": "APPROVE",
            "effects": [
              [
                "set",
                "@entity.status",
                "done"
              ],
              [
                "emit",
                "TASK_COMPLETED",
                "@entity"
              ]
            ]
          },
          {
            "from": "in_review",
            "to": "in_progress",
            "event": "REQUEST_CHANGES",
            "effects": [
              [
                "set",
                "@entity.status",
                "in_progress"
              ],
              [
                "emit",
                "TASK_UPDATED",
                "@entity"
              ]
            ]
          },
          {
            "from": "done",
            "to": "todo",
            "event": "REOPEN",
            "effects": [
              [
                "set",
                "@entity.status",
                "todo"
              ],
              [
                "emit",
                "TASK_UPDATED",
                "@entity"
              ]
            ]
          }
        ]
      }
    }
  ]
}