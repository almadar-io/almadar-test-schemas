{
  "name": "Contact Management",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "Contact Management",
      "entity": {
        "name": "Contact",
        "collection": "contacts",
        "fields": [
          {
            "name": "name",
            "type": "string",
            "required": true
          },
          {
            "name": "email",
            "type": "string",
            "required": true
          },
          {
            "name": "phone",
            "type": "string"
          },
          {
            "name": "notes",
            "type": "string"
          }
        ]
      },
      "traits": [
        {
          "name": "ContactInteraction",
          "category": "interaction",
          "linkedEntity": "Contact",
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "viewing"
              },
              {
                "name": "editing"
              },
              {
                "name": "deleting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "VIEW",
                "name": "View"
              },
              {
                "key": "EDIT",
                "name": "Edit"
              },
              {
                "key": "DELETE",
                "name": "Delete"
              },
              {
                "key": "SAVE",
                "name": "Save"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "page-header",
                      "title": "Contacts",
                      "actions": [
                        {
                          "label": "New Contact",
                          "event": "CREATE",
                          "variant": "primary"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "search-bar",
                      "placeholder": "Search contacts...",
                      "entity": "Contact"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "entity-table",
                      "entity": "Contact",
                      "columns": [
                        "name",
                        "email",
                        "phone"
                      ],
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW",
                          "placement": "row"
                        },
                        {
                          "label": "Edit",
                          "event": "EDIT",
                          "placement": "menu"
                        },
                        {
                          "label": "Delete",
                          "event": "DELETE",
                          "placement": "menu",
                          "isDestructive": true
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "creating",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Contact",
                      "fields": [
                        {
                          "field": "name",
                          "label": "Name",
                          "inputType": "text"
                        },
                        {
                          "field": "email",
                          "label": "Email",
                          "inputType": "email"
                        },
                        {
                          "field": "phone",
                          "label": "Phone",
                          "inputType": "text"
                        },
                        {
                          "field": "notes",
                          "label": "Notes",
                          "inputType": "textarea"
                        }
                      ],
                      "onSubmit": "SAVE",
                      "onCancel": "CLOSE"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "type": "entity-detail",
                      "entity": "Contact",
                      "fieldNames": [
                        "name",
                        "email",
                        "phone",
                        "notes"
                      ],
                      "headerActions": [
                        {
                          "label": "Edit",
                          "event": "EDIT",
                          "variant": "primary"
                        },
                        {
                          "label": "Delete",
                          "event": "DELETE",
                          "variant": "danger"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Contact",
                      "fields": [
                        {
                          "field": "name",
                          "label": "Name",
                          "inputType": "text"
                        },
                        {
                          "field": "email",
                          "label": "Email",
                          "inputType": "email"
                        },
                        {
                          "field": "phone",
                          "label": "Phone",
                          "inputType": "text"
                        },
                        {
                          "field": "notes",
                          "label": "Notes",
                          "inputType": "textarea"
                        }
                      ],
                      "onSubmit": "SAVE",
                      "onCancel": "CLOSE"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Contact",
                      "fields": [
                        {
                          "field": "name",
                          "label": "Name",
                          "inputType": "text"
                        },
                        {
                          "field": "email",
                          "label": "Email",
                          "inputType": "email"
                        },
                        {
                          "field": "phone",
                          "label": "Phone",
                          "inputType": "text"
                        },
                        {
                          "field": "notes",
                          "label": "Notes",
                          "inputType": "textarea"
                        }
                      ],
                      "onSubmit": "SAVE",
                      "onCancel": "CLOSE"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "deleting",
                "event": "DELETE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "confirmation",
                      "title": "Delete Contact",
                      "message": "Are you sure you want to delete this contact? This action cannot be undone.",
                      "onConfirm": "CONFIRM_DELETE",
                      "onCancel": "CANCEL"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "deleting",
                "event": "DELETE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "confirmation",
                      "title": "Delete Contact",
                      "message": "Are you sure you want to delete this contact? This action cannot be undone.",
                      "onConfirm": "CONFIRM_DELETE",
                      "onCancel": "CANCEL"
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "persist",
                    "create",
                    "Contact",
                    "@form"
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "success",
                      "message": "Contact created successfully"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "persist",
                    "update",
                    "Contact",
                    "@form"
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "success",
                      "message": "Contact updated successfully"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "browsing",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "persist",
                    "delete",
                    "Contact",
                    "@entity"
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "success",
                      "message": "Contact deleted successfully"
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "viewing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "ContactsPage",
          "path": "/contacts",
          "viewType": "list",
          "primaryEntity": "Contact",
          "isInitial": true,
          "traits": [
            {
              "ref": "ContactInteraction"
            }
          ]
        }
      ],
      "emits": [
        "CONTACT_CREATED",
        "CONTACT_UPDATED",
        "CONTACT_DELETED"
      ],
      "listens": []
    }
  ]
}