{
  "name": "Notes Management with Note entity, list view in table format, and click-to-view details in drawer",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "Notes Management",
      "entity": {
        "name": "Note",
        "collection": "notes",
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string"
          },
          {
            "name": "createdAt",
            "type": "date"
          },
          {
            "name": "updatedAt",
            "type": "date"
          },
          {
            "name": "tags",
            "type": "array"
          },
          {
            "name": "isPinned",
            "type": "boolean",
            "default": false
          }
        ]
      },
      "traits": [
        {
          "name": "NoteInteraction",
          "category": "interaction",
          "linkedEntity": "Note",
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "viewing"
              },
              {
                "name": "editing"
              },
              {
                "name": "searching"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "VIEW",
                "name": "View"
              },
              {
                "key": "EDIT",
                "name": "Edit"
              },
              {
                "key": "SEARCH",
                "name": "Search"
              },
              {
                "key": "DELETE",
                "name": "Delete"
              },
              {
                "key": "PIN",
                "name": "Pin"
              },
              {
                "key": "SAVE",
                "name": "Save"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "page-header",
                      "title": "Notes",
                      "actions": [
                        {
                          "label": "New Note",
                          "event": "CREATE",
                          "variant": "primary"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "search-bar",
                      "placeholder": "Search notes...",
                      "entity": "Note"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "entity-cards",
                      "entity": "Note",
                      "fieldNames": [
                        "title",
                        "content",
                        "createdAt"
                      ],
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW",
                          "placement": "row"
                        },
                        {
                          "label": "Edit",
                          "event": "EDIT",
                          "placement": "menu"
                        },
                        {
                          "label": "Pin",
                          "event": "PIN",
                          "placement": "menu"
                        },
                        {
                          "label": "Delete",
                          "event": "DELETE",
                          "placement": "menu",
                          "isDestructive": true
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "creating",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Note",
                      "fields": [
                        {
                          "field": "title",
                          "label": "Title",
                          "inputType": "text"
                        },
                        {
                          "field": "content",
                          "label": "Content",
                          "inputType": "textarea"
                        },
                        {
                          "field": "tags",
                          "label": "Tags",
                          "inputType": "text",
                          "placeholder": "Comma-separated tags"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-actions",
                      "primary": {
                        "label": "Create Note",
                        "event": "SAVE",
                        "actionType": "submit",
                        "variant": "primary"
                      },
                      "secondary": [
                        {
                          "label": "Cancel",
                          "event": "CANCEL",
                          "actionType": "cancel",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "type": "entity-detail",
                      "entity": "Note",
                      "fieldNames": [
                        "title",
                        "content",
                        "createdAt",
                        "updatedAt",
                        "tags"
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "drawer",
                    {
                      "type": "action-bar",
                      "actions": [
                        {
                          "label": "Edit",
                          "event": "EDIT",
                          "variant": "primary"
                        },
                        {
                          "label": "Pin",
                          "event": "PIN",
                          "variant": "secondary"
                        },
                        {
                          "label": "Delete",
                          "event": "DELETE",
                          "variant": "danger"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "searching",
                "event": "SEARCH",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "filter-group",
                      "filters": [
                        {
                          "field": "title",
                          "filterType": "search",
                          "label": "Title"
                        },
                        {
                          "field": "content",
                          "filterType": "search",
                          "label": "Content"
                        },
                        {
                          "field": "isPinned",
                          "filterType": "checkbox",
                          "label": "Pinned Only"
                        },
                        {
                          "field": "createdAt",
                          "filterType": "date-range",
                          "label": "Created Date"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Note",
                      "fields": [
                        {
                          "field": "title",
                          "label": "Title",
                          "inputType": "text"
                        },
                        {
                          "field": "content",
                          "label": "Content",
                          "inputType": "textarea"
                        },
                        {
                          "field": "tags",
                          "label": "Tags",
                          "inputType": "text"
                        },
                        {
                          "field": "isPinned",
                          "label": "Pin Note",
                          "inputType": "checkbox"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-actions",
                      "primary": {
                        "label": "Save Changes",
                        "event": "SAVE",
                        "actionType": "submit",
                        "variant": "primary"
                      },
                      "secondary": [
                        {
                          "label": "Cancel",
                          "event": "CANCEL",
                          "actionType": "cancel",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Note",
                    "@entity"
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Note deleted successfully",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "browsing",
                "event": "DELETE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "persist",
                    "delete",
                    "Note",
                    "@entity"
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Note deleted successfully",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "browsing",
                "event": "PIN",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Note",
                    {
                      "isPinned": true
                    }
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Note pinned",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "browsing",
                "event": "PIN",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "persist",
                    "update",
                    "Note",
                    {
                      "isPinned": true
                    }
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Note pinned",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "persist",
                    "create",
                    "Note",
                    "@form"
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Note created successfully",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "persist",
                    "update",
                    "Note",
                    "@form"
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "notification",
                      "message": "Note updated successfully",
                      "variant": "success"
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ]
                ]
              },
              {
                "from": "searching",
                "to": "browsing",
                "event": "CLOSE",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "entity-cards",
                      "entity": "Note",
                      "fieldNames": [
                        "title",
                        "content",
                        "createdAt"
                      ]
                    }
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "NotesPage",
          "path": "/notes",
          "viewType": "list",
          "primaryEntity": "Note",
          "isInitial": true,
          "traits": [
            {
              "ref": "NoteInteraction"
            }
          ]
        }
      ],
      "emits": [
        "NOTE_CREATED",
        "NOTE_UPDATED",
        "NOTE_DELETED",
        "NOTE_PINNED"
      ],
      "listens": []
    }
  ]
}