{
  "name": "Notes Management",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "Notes Management",
      "entity": {
        "name": "Note",
        "collection": "notes",
        "fields": [
          {
            "name": "title",
            "type": "string",
            "required": true
          },
          {
            "name": "content",
            "type": "string",
            "required": true
          },
          {
            "name": "createdAt",
            "type": "date",
            "required": true
          },
          {
            "name": "updatedAt",
            "type": "date",
            "required": true
          }
        ]
      },
      "traits": [
        {
          "name": "EntityManagement",
          "category": "interaction",
          "linkedEntity": "Note",
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "viewing"
              },
              {
                "name": "editing"
              },
              {
                "name": "deleting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create"
              },
              {
                "key": "VIEW",
                "name": "View"
              },
              {
                "key": "EDIT",
                "name": "Edit"
              },
              {
                "key": "DELETE",
                "name": "Delete"
              },
              {
                "key": "SAVE",
                "name": "Save"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "page-header",
                      "title": "Notes",
                      "actions": [
                        {
                          "label": "New Note",
                          "event": "CREATE",
                          "variant": "primary"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "search-bar",
                      "placeholder": "Search notes...",
                      "entity": "Note"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "entity-cards",
                      "entity": "Note",
                      "fieldNames": [
                        "title",
                        "content",
                        "createdAt"
                      ],
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW",
                          "placement": "row"
                        },
                        {
                          "label": "Edit",
                          "event": "EDIT",
                          "placement": "menu"
                        },
                        {
                          "label": "Delete",
                          "event": "DELETE",
                          "placement": "menu",
                          "isDestructive": true
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "creating",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Note",
                      "fields": [
                        {
                          "field": "title",
                          "label": "Title",
                          "inputType": "text"
                        },
                        {
                          "field": "content",
                          "label": "Content",
                          "inputType": "textarea"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-actions",
                      "primary": {
                        "label": "Save",
                        "event": "SAVE",
                        "actionType": "submit",
                        "variant": "primary"
                      },
                      "secondary": [
                        {
                          "label": "Cancel",
                          "event": "CANCEL",
                          "actionType": "cancel",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "type": "entity-detail",
                      "entity": "Note",
                      "fieldNames": [
                        "title",
                        "content",
                        "createdAt",
                        "updatedAt"
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "drawer",
                    {
                      "type": "page-header",
                      "title": "Note Details",
                      "actions": [
                        {
                          "label": "Edit",
                          "event": "EDIT",
                          "variant": "primary"
                        },
                        {
                          "label": "Delete",
                          "event": "DELETE",
                          "variant": "danger"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Note",
                      "fields": [
                        {
                          "field": "title",
                          "label": "Title",
                          "inputType": "text"
                        },
                        {
                          "field": "content",
                          "label": "Content",
                          "inputType": "textarea"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-actions",
                      "primary": {
                        "label": "Save Changes",
                        "event": "SAVE",
                        "actionType": "submit",
                        "variant": "primary"
                      },
                      "secondary": [
                        {
                          "label": "Cancel",
                          "event": "CANCEL",
                          "actionType": "cancel",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "deleting",
                "event": "DELETE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "confirmation-dialog",
                      "title": "Delete Note",
                      "message": "Are you sure you want to delete this note? This action cannot be undone.",
                      "confirmLabel": "Delete",
                      "cancelLabel": "Cancel",
                      "confirmEvent": "CONFIRM_DELETE",
                      "cancelEvent": "CANCEL",
                      "variant": "danger"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "entity": "Note",
                      "fields": [
                        {
                          "field": "title",
                          "label": "Title",
                          "inputType": "text"
                        },
                        {
                          "field": "content",
                          "label": "Content",
                          "inputType": "textarea"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-actions",
                      "primary": {
                        "label": "Save Changes",
                        "event": "SAVE",
                        "actionType": "submit",
                        "variant": "primary"
                      },
                      "secondary": [
                        {
                          "label": "Cancel",
                          "event": "CANCEL",
                          "actionType": "cancel",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "deleting",
                "event": "DELETE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "confirmation-dialog",
                      "title": "Delete Note",
                      "message": "Are you sure you want to delete this note? This action cannot be undone.",
                      "confirmLabel": "Delete",
                      "cancelLabel": "Cancel",
                      "confirmEvent": "CONFIRM_DELETE",
                      "cancelEvent": "CANCEL",
                      "variant": "danger"
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Note",
                    "@form"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "success",
                      "message": "Note created successfully"
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Note",
                    "@form"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "success",
                      "message": "Note updated successfully"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "browsing",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Note",
                    "@entity"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "success",
                      "message": "Note deleted successfully"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "browsing",
                "event": "CANCEL",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    null
                  ]
                ]
              }
            ]
          }
        }
      ],
      "pages": [
        {
          "name": "NotesPage",
          "path": "/notes",
          "viewType": "list",
          "primaryEntity": "Note",
          "isInitial": true,
          "traits": [
            {
              "ref": "EntityManagement"
            }
          ]
        }
      ],
      "emits": [
        "NOTE_CREATED",
        "NOTE_UPDATED",
        "NOTE_DELETED"
      ],
      "listens": []
    }
  ]
}