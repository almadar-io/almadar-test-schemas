{
  "name": "Notes Management",
  "entity": {
    "name": "Note",
    "collection": "notes",
    "fields": [
      {
        "name": "title",
        "type": "string",
        "required": true
      },
      {
        "name": "content",
        "type": "string"
      },
      {
        "name": "createdAt",
        "type": "date",
        "required": true
      },
      {
        "name": "updatedAt",
        "type": "date",
        "required": true
      },
      {
        "name": "tags",
        "type": "array"
      },
      {
        "name": "isPinned",
        "type": "boolean",
        "default": false
      }
    ]
  },
  "traits": [
    {
      "name": "NoteManagement",
      "category": "interaction",
      "linkedEntity": "Note",
      "stateMachine": {
        "states": [
          {
            "name": "browsing",
            "isInitial": true
          },
          {
            "name": "creating"
          },
          {
            "name": "viewing"
          },
          {
            "name": "editing"
          },
          {
            "name": "confirming_delete"
          }
        ],
        "events": [
          {
            "key": "INIT",
            "name": "Initialize"
          },
          {
            "key": "CREATE",
            "name": "Create"
          },
          {
            "key": "VIEW",
            "name": "View"
          },
          {
            "key": "EDIT",
            "name": "Edit"
          },
          {
            "key": "DELETE",
            "name": "Delete"
          },
          {
            "key": "CONFIRM_DELETE",
            "name": "Confirm Delete"
          },
          {
            "key": "SAVE",
            "name": "Save"
          },
          {
            "key": "CLOSE",
            "name": "Close"
          },
          {
            "key": "CANCEL",
            "name": "Cancel"
          },
          {
            "key": "SEARCH",
            "name": "Search"
          },
          {
            "key": "FILTER",
            "name": "Filter"
          }
        ],
        "transitions": [
          {
            "from": "browsing",
            "to": "browsing",
            "event": "INIT",
            "effects": [
              [
                "render-ui",
                "main",
                {
                  "type": "page-header",
                  "title": "Notes",
                  "subtitle": "Manage your notes and ideas",
                  "actions": [
                    {
                      "label": "New Note",
                      "event": "CREATE",
                      "variant": "primary"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "search-bar",
                  "placeholder": "Search notes...",
                  "entity": "Note"
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "filter-group",
                  "filters": [
                    {
                      "field": "isPinned",
                      "filterType": "checkbox",
                      "label": "Pinned Only"
                    },
                    {
                      "field": "createdAt",
                      "filterType": "date-range",
                      "label": "Created Date"
                    }
                  ]
                }
              ],
              [
                "render-ui",
                "main",
                {
                  "type": "entity-cards",
                  "entity": "Note",
                  "fieldNames": [
                    "title",
                    "content",
                    "createdAt",
                    "isPinned"
                  ],
                  "itemActions": [
                    {
                      "label": "View",
                      "event": "VIEW",
                      "placement": "row"
                    },
                    {
                      "label": "Edit",
                      "event": "EDIT",
                      "placement": "menu"
                    },
                    {
                      "label": "Delete",
                      "event": "DELETE",
                      "placement": "menu",
                      "isDestructive": true
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "creating",
            "event": "CREATE",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "title": "Create New Note",
                  "entity": "Note",
                  "fields": [
                    {
                      "field": "title",
                      "label": "Title",
                      "inputType": "text"
                    },
                    {
                      "field": "content",
                      "label": "Content",
                      "inputType": "textarea"
                    },
                    {
                      "field": "tags",
                      "label": "Tags",
                      "inputType": "text",
                      "placeholder": "Comma-separated tags"
                    },
                    {
                      "field": "isPinned",
                      "label": "Pin Note",
                      "inputType": "checkbox"
                    }
                  ],
                  "onSubmit": "SAVE",
                  "onCancel": "CLOSE"
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "viewing",
            "event": "VIEW",
            "effects": [
              [
                "render-ui",
                "drawer",
                {
                  "type": "entity-detail",
                  "entity": "Note",
                  "fieldNames": [
                    "title",
                    "content",
                    "tags",
                    "createdAt",
                    "updatedAt",
                    "isPinned"
                  ],
                  "headerActions": [
                    {
                      "label": "Edit",
                      "event": "EDIT",
                      "variant": "primary"
                    },
                    {
                      "label": "Delete",
                      "event": "DELETE",
                      "variant": "danger"
                    }
                  ]
                }
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "editing",
            "event": "EDIT",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "form-section",
                  "title": "Edit Note",
                  "entity": "Note",
                  "fields": [
                    {
                      "field": "title",
                      "label": "Title",
                      "inputType": "text"
                    },
                    {
                      "field": "content",
                      "label": "Content",
                      "inputType": "textarea"
                    },
                    {
                      "field": "tags",
                      "label": "Tags",
                      "inputType": "text",
                      "placeholder": "Comma-separated tags"
                    },
                    {
                      "field": "isPinned",
                      "label": "Pin Note",
                      "inputType": "checkbox"
                    }
                  ],
                  "onSubmit": "SAVE",
                  "onCancel": "CLOSE"
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "confirming_delete",
            "event": "DELETE",
            "effects": [
              [
                "render-ui",
                "modal",
                {
                  "type": "confirmation",
                  "title": "Delete Note",
                  "message": "Are you sure you want to delete this note? This action cannot be undone.",
                  "onConfirm": "CONFIRM_DELETE",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "confirming_delete",
            "event": "DELETE",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ],
              [
                "render-ui",
                "modal",
                {
                  "type": "confirmation",
                  "title": "Delete Note",
                  "message": "Are you sure you want to delete this note? This action cannot be undone.",
                  "onConfirm": "CONFIRM_DELETE",
                  "onCancel": "CANCEL"
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "persist",
                "create",
                "Note",
                "@form"
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "success",
                  "message": "Note created successfully"
                }
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "SAVE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "persist",
                "update",
                "Note",
                "@form"
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "success",
                  "message": "Note updated successfully"
                }
              ]
            ]
          },
          {
            "from": "confirming_delete",
            "to": "browsing",
            "event": "CONFIRM_DELETE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ],
              [
                "persist",
                "delete",
                "Note",
                "@entity"
              ],
              [
                "render-ui",
                "toast",
                {
                  "type": "success",
                  "message": "Note deleted successfully"
                }
              ]
            ]
          },
          {
            "from": "creating",
            "to": "browsing",
            "event": "CLOSE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "editing",
            "to": "browsing",
            "event": "CLOSE",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "viewing",
            "to": "browsing",
            "event": "CLOSE",
            "effects": [
              [
                "render-ui",
                "drawer",
                null
              ]
            ]
          },
          {
            "from": "confirming_delete",
            "to": "browsing",
            "event": "CANCEL",
            "effects": [
              [
                "render-ui",
                "modal",
                null
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "browsing",
            "event": "SEARCH",
            "effects": [
              [
                "filter",
                "Note",
                {
                  "field": "title",
                  "operator": "contains",
                  "value": "@searchTerm"
                }
              ],
              [
                "filter",
                "Note",
                {
                  "field": "content",
                  "operator": "contains",
                  "value": "@searchTerm"
                }
              ]
            ]
          },
          {
            "from": "browsing",
            "to": "browsing",
            "event": "FILTER",
            "effects": [
              [
                "filter",
                "Note",
                "@filterCriteria"
              ]
            ]
          }
        ]
      }
    }
  ],
  "pages": [
    {
      "name": "NotesPage",
      "path": "/notes",
      "viewType": "list",
      "primaryEntity": "Note",
      "isInitial": true,
      "traits": [
        {
          "ref": "NoteManagement"
        }
      ]
    }
  ],
  "emits": [
    "NOTE_CREATED",
    "NOTE_UPDATED",
    "NOTE_DELETED",
    "NOTE_VIEWED"
  ],
  "listens": [
    "SEARCH_PERFORMED",
    "FILTER_APPLIED"
  ]
}