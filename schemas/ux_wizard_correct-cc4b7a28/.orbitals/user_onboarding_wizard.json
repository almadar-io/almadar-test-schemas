{
  "name": "User Onboarding Wizard",
  "entity": {
    "name": "UserOnboarding",
    "runtime": true,
    "singleton": true,
    "fields": [
      {
        "name": "currentStep",
        "type": "number",
        "required": true,
        "default": 1
      },
      {
        "name": "name",
        "type": "string",
        "required": false
      },
      {
        "name": "email",
        "type": "string",
        "required": false
      },
      {
        "name": "theme",
        "type": "enum",
        "values": [
          "light",
          "dark",
          "auto"
        ],
        "default": "light"
      },
      {
        "name": "notifications",
        "type": "boolean",
        "required": true,
        "default": true
      },
      {
        "name": "completed",
        "type": "boolean",
        "required": true,
        "default": false
      }
    ]
  },
  "traits": [
