          {
            "name": "personalInfo"
          },
          {
            "name": "preferences"
          },
          {
            "name": "complete"
          }
        ],
        "events": [
          {
            "key": "INIT",
            "name": "Initialize"
          },
          {
            "key": "NEXT",
            "name": "Next Step"
          },
          {
            "key": "BACK",
            "name": "Previous Step"
          },
          {
            "key": "SKIP",
            "name": "Skip Step"
          },
          {
            "key": "FINISH",
            "name": "Finish Onboarding"
          },
          {
            "key": "RESTART",
            "name": "Restart Onboarding"
          }
