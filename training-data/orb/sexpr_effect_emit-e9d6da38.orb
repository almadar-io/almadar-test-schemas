{
  "name": "Order Management, Customer Management, and Notification System for an order notification system with state transitions and event-driven communication",
  "version": "1.0.0",
  "orbitals": [
    {
      "name": "Customer Management",
      "entity": {
        "name": "Customer",
        "collection": "customers",
        "fields": [
          {
            "name": "email",
            "type": "string",
            "required": true
          },
          {
            "name": "firstName",
            "type": "string",
            "required": true
          },
          {
            "name": "lastName",
            "type": "string",
            "required": true
          },
          {
            "name": "phone",
            "type": "string"
          },
          {
            "name": "totalOrders",
            "type": "number",
            "default": 0
          },
          {
            "name": "totalSpent",
            "type": "number",
            "default": 0
          },
          {
            "name": "status",
            "type": "enum",
            "enum": [
              "active",
              "inactive",
              "blocked"
            ]
          },
          {
            "name": "joinDate",
            "type": "date"
          },
          {
            "name": "lastOrderDate",
            "type": "date"
          }
        ]
      },
      "traits": [
        {
          "name": "CustomerInteraction",
          "category": "interaction",
          "linkedEntity": "Customer",
          "stateMachine": {
            "states": [
              {
                "name": "browsing",
                "isInitial": true
              },
              {
                "name": "creating"
              },
              {
                "name": "viewing"
              },
              {
                "name": "editing"
              },
              {
                "name": "deleting"
              }
            ],
            "events": [
              {
                "key": "INIT",
                "name": "Initialize"
              },
              {
                "key": "CREATE",
                "name": "Create Customer"
              },
              {
                "key": "VIEW",
                "name": "View Customer"
              },
              {
                "key": "EDIT",
                "name": "Edit Customer"
              },
              {
                "key": "DELETE",
                "name": "Delete Customer"
              },
              {
                "key": "CONFIRM_DELETE",
                "name": "Confirm Delete"
              },
              {
                "key": "SAVE",
                "name": "Save"
              },
              {
                "key": "CLOSE",
                "name": "Close"
              },
              {
                "key": "CANCEL",
                "name": "Cancel"
              }
            ],
            "transitions": [
              {
                "from": "browsing",
                "to": "browsing",
                "event": "INIT",
                "effects": [
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "page-header",
                      "title": "Customers",
                      "actions": [
                        {
                          "label": "New Customer",
                          "event": "CREATE",
                          "variant": "primary"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "search-bar",
                      "placeholder": "Search customers...",
                      "entity": "Customer"
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "filter-group",
                      "filters": [
                        {
                          "field": "status",
                          "filterType": "select",
                          "label": "Status",
                          "options": [
                            "active",
                            "inactive",
                            "blocked"
                          ]
                        },
                        {
                          "field": "joinDate",
                          "filterType": "date-range",
                          "label": "Join Date"
                        },
                        {
                          "field": "totalOrders",
                          "filterType": "number-range",
                          "label": "Total Orders"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "main",
                    {
                      "type": "entity-table",
                      "entity": "Customer",
                      "columns": [
                        "firstName",
                        "lastName",
                        "email",
                        "totalOrders",
                        "totalSpent",
                        "status"
                      ],
                      "itemActions": [
                        {
                          "label": "View",
                          "event": "VIEW",
                          "placement": "row"
                        },
                        {
                          "label": "Edit",
                          "event": "EDIT",
                          "placement": "menu"
                        },
                        {
                          "label": "Delete",
                          "event": "DELETE",
                          "placement": "menu",
                          "isDestructive": true
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "creating",
                "event": "CREATE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "title": "Create Customer",
                      "entity": "Customer",
                      "fields": [
                        {
                          "field": "firstName",
                          "label": "First Name",
                          "inputType": "text"
                        },
                        {
                          "field": "lastName",
                          "label": "Last Name",
                          "inputType": "text"
                        },
                        {
                          "field": "email",
                          "label": "Email",
                          "inputType": "email"
                        },
                        {
                          "field": "phone",
                          "label": "Phone",
                          "inputType": "text"
                        },
                        {
                          "field": "status",
                          "label": "Status",
                          "inputType": "select",
                          "values": [
                            "active",
                            "inactive",
                            "blocked"
                          ]
                        },
                        {
                          "field": "joinDate",
                          "label": "Join Date",
                          "inputType": "date"
                        }
                      ]
                    }
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-actions",
                      "primary": {
                        "label": "Create Customer",
                        "event": "SAVE",
                        "actionType": "submit",
                        "variant": "primary"
                      },
                      "secondary": [
                        {
                          "label": "Cancel",
                          "event": "CLOSE",
                          "actionType": "cancel",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "viewing",
                "event": "VIEW",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    {
                      "type": "entity-detail",
                      "entity": "Customer",
                      "fieldNames": [
                        "firstName",
                        "lastName",
                        "email",
                        "phone",
                        "totalOrders",
                        "totalSpent",
                        "status",
                        "joinDate",
                        "lastOrderDate"
