      "pages": [
        {
          "name": "CustomersPage",
          "path": "/customers",
          "viewType": "list",
          "isInitial": true,
          "traits": [
            {
              "ref": "CustomerInteraction"
            }
          ],
          "entity": "Customer"
        }
      ],
      "emits": [
        "CUSTOMER_CREATED",
        "CUSTOMER_UPDATED",
        "CUSTOMER_DELETED"
      ],
      "listens": [
        "ORDER_PLACED",
        "ORDER_CANCELLED"
      ]
    },
    {
      "name": "Notification System",
      "entity": {
        "name": "Notification",
        "collection": "notifications",
        "fields": [
          {
            "name": "type",
            "type": "enum",
            "required": true,
            "enum": [
              "info",
              "warning",
              "error",
              "success"
            ]
          },
          {
            "name": "message",
            "type": "string",
            "required": true
          },
          {
            "name": "recipient",
            "type": "string",
            "required": true
          },
          {
            "name": "status",
            "type": "enum",
            "required": true,
            "default": "unread",
            "enum": [
              "unread",
              "read",
              "dismissed"
            ]
          },
          {
            "name": "createdAt",
            "type": "date",
            "required": true
          }
        ]
      },
