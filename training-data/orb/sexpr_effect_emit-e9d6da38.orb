                          "variant": "danger"
                        },
                        {
                          "label": "Close",
                          "event": "CLOSE",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "editing",
                "event": "EDIT",
                "effects": [
