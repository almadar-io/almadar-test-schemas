                          "label": "Last Name",
                          "inputType": "text"
                        },
                        {
                          "field": "email",
                          "label": "Email",
                          "inputType": "email"
                        },
                        {
                          "field": "phone",
                          "label": "Phone",
                          "inputType": "text"
                        },
                        {
                          "field": "status",
                          "label": "Status",
