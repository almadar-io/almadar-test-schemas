                          "label": "Cancel",
                          "event": "CLOSE",
                          "actionType": "cancel",
                          "variant": "secondary"
                        }
                      ]
                    }
                  ]
                ]
              },
              {
                "from": "browsing",
                "to": "deleting",
                "event": "DELETE",
                "effects": [
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "confirmation-dialog",
                      "title": "Delete Customer",
                      "message": "Are you sure you want to delete this customer? This action cannot be undone.",
                      "confirmLabel": "Delete",
                      "cancelLabel": "Cancel",
                      "confirmEvent": "CONFIRM_DELETE",
                      "cancelEvent": "CANCEL",
                      "variant": "danger"
                    }
                  ]
                ]
              },
              {
                "from": "viewing",
                "to": "deleting",
                "event": "DELETE",
                "effects": [
                  [
                    "render-ui",
                    "drawer",
                    null
                  ],
                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "confirmation-dialog",
                      "title": "Delete Customer",
                      "message": "Are you sure you want to delete this customer? This action cannot be undone.",
                      "confirmLabel": "Delete",
                      "cancelLabel": "Cancel",
                      "confirmEvent": "CONFIRM_DELETE",
                      "cancelEvent": "CANCEL",
                      "variant": "danger"
                    }
                  ]
                ]
              },
              {
                "from": "creating",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "create",
                    "Customer",
                    "@entity"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "success",
                      "message": "Customer created successfully"
                    }
                  ]
                ]
              },
              {
                "from": "editing",
                "to": "browsing",
                "event": "SAVE",
                "effects": [
                  [
                    "persist",
                    "update",
                    "Customer",
                    "@entity"
                  ],
                  [
                    "render-ui",
                    "modal",
                    null
                  ],
                  [
                    "render-ui",
                    "toast",
                    {
                      "type": "success",
                      "message": "Customer updated successfully"
                    }
                  ]
                ]
              },
              {
                "from": "deleting",
                "to": "browsing",
                "event": "CONFIRM_DELETE",
                "effects": [
                  [
                    "persist",
                    "delete",
                    "Customer",
                    "@entity"
