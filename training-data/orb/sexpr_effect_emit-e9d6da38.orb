                  [
                    "render-ui",
                    "modal",
                    {
                      "type": "form-section",
                      "title": "Edit Customer",
                      "entity": "Customer",
                      "fields": [
                        {
                          "field": "firstName",
                          "label": "First Name",
                          "inputType": "text"
                        },
                        {
                          "field": "lastName",
