                            "blocked"
                          ]
                        },
                        {
                          "field": "totalOrders",
                          "label": "Total Orders",
                          "inputType": "number"
                        },
                        {
                          "field": "totalSpent",
                          "label": "Total Spent",
                          "inputType": "number"
                        },
                        {
                          "field": "lastOrderDate",
                          "label": "Last Order Date",
                          "inputType": "date"
